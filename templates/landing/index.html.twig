{# templates/landing/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Welcome to SMSol Studio{% endblock %}

{% block body %}
<!-- Hero Section -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="fw-bold text-white mb-4">SMSol Studio</h1>
                <p class="lead text-white mb-4">Discover curated clothing and accessories from our studio — quality fashion, delivered.</p>
                <div class="d-flex gap-3">
                    {% if app.user %}
                        <a href="{{ path('app_dashboard') }}" class="btn btn-light btn-lg px-4">
                            <i class="bi bi-speedometer2 me-2"></i>Go to Dashboard
                        </a>
                    {% else %}
                        <a href="{{ path('app_register') }}" class="btn btn-light btn-lg px-4">
                            <i class="bi bi-person-plus me-2"></i>Get Started
                        </a>
                        <a href="{{ path('app_services') }}" class="btn btn-outline-light btn-lg px-4">
                            <i class="bi bi-info-circle me-2"></i>Learn More
                        </a>
                    {% endif %}
                </div>
            </div>
            <div class="col-lg-6 text-center">
                <img src="{{ asset('images/hero-fashion.jpg') }}" alt="SMSol Studio Fashion" class="img-fluid rounded shadow">
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Our Services</h2>
            <p class="text-muted">Premium clothing services tailored for you</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card service-card h-100">
                    <div class="card-body text-center p-4">
                        <div class="icon-wrapper bg-primary rounded-circle p-3 mb-3 mx-auto">
                            <i class="bi bi-tshirt text-white fs-3"></i>
                        </div>
                        <h4 class="card-title">Premium Clothing</h4>
                        <p class="card-text text-muted">Curated collection of high-quality clothing and accessories.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card service-card h-100">
                    <div class="card-body text-center p-4">
                        <div class="icon-wrapper bg-success rounded-circle p-3 mb-3 mx-auto">
                            <i class="bi bi-truck text-white fs-3"></i>
                        </div>
                        <h4 class="card-title">Fast Delivery</h4>
                        <p class="card-text text-muted">Quick and reliable delivery services to your doorstep.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card service-card h-100">
                    <div class="card-body text-center p-4">
                        <div class="icon-wrapper bg-warning rounded-circle p-3 mb-3 mx-auto">
                            <i class="bi bi-star text-white fs-3"></i>
                        </div>
                        <h4 class="card-title">Quality Assurance</h4>
                        <p class="card-text text-muted">Every item is carefully inspected for quality and perfection.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- How It Works -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">How It Works</h2>
            <p class="text-muted">Simple steps to get your fashion items</p>
        </div>
        <div class="row">
            <div class="col-lg-3 col-md-6">
                <div class="text-center mb-4">
                    <div class="step-number rounded-circle d-inline-flex align-items-center justify-content-center mb-3">
                        <span class="fs-4 fw-bold">1</span>
                    </div>
                    <h5>Browse Collection</h5>
                    <p class="text-muted">Explore our curated fashion collection online</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="text-center mb-4">
                    <div class="step-number rounded-circle d-inline-flex align-items-center justify-content-center mb-3">
                        <span class="fs-4 fw-bold">2</span>
                    </div>
                    <h5>Place Order</h5>
                    <p class="text-muted">Select items and place your order</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="text-center mb-4">
                    <div class="step-number rounded-circle d-inline-flex align-items-center justify-content-center mb-3">
                        <span class="fs-4 fw-bold">3</span>
                    </div>
                    <h5>We Process</h5>
                    <p class="text-muted">We prepare and quality-check your order</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="text-center mb-4">
                    <div class="step-number rounded-circle d-inline-flex align-items-center justify-content-center mb-3">
                        <span class="fs-4 fw-bold">4</span>
                    </div>
                    <h5>Receive Delivery</h5>
                    <p class="text-muted">Get your fashion items delivered to you</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stats Section -->
<section class="py-5 bg-dark text-white stats-section">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-3 mb-4">
                <h2 class="fw-bold">2,000+</h2>
                <p class="text-light">Happy Customers</p>
            </div>
            <div class="col-md-3 mb-4">
                <h2 class="fw-bold">500+</h2>
                <p class="text-light">Fashion Items</p>
            </div>
            <div class="col-md-3 mb-4">
                <h2 class="fw-bold">1,600+</h2>
                <p class="text-light">Orders Completed</p>
            </div>
            <div class="col-md-3 mb-4">
                <h2 class="fw-bold">24/7</h2>
                <p class="text-light">Support Available</p>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="py-5">
    <div class="container text-center">
        <h2 class="fw-bold mb-4">Ready to Shop Fashion?</h2>
        <p class="lead mb-4">Join thousands of satisfied customers who trust SMSol Studio for premium fashion.</p>
        {% if app.user %}
            <a href="{{ path('app_products') }}" class="btn btn-primary btn-lg px-5">
                <i class="bi bi-bag me-2"></i>Browse Products
            </a>
        {% else %}
            <a href="{{ path('app_register') }}" class="btn btn-primary btn-lg px-5">
                <i class="bi bi-rocket-takeoff me-2"></i>Start Shopping Now
            </a>
        {% endif %}
    </div>
</section>
{% endblock %}