{# templates/landing/about.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}About Us - SMSol Studio{% endblock %}

{% block body %}
<!-- Hero Section -->
<section class="hero-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center">
                <h1 class="fw-bold text-white mb-3">About SMSol Studio</h1>
                <p class="lead text-white mb-0">Where fashion meets quality and style meets convenience</p>
            </div>
        </div>
    </div>
</section>

<!-- Our Story -->
<section class="py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <h2 class="fw-bold mb-4">Our Story</h2>
                <p class="lead mb-4">
                    Founded in 2020, SMSol Studio began with a simple vision: to provide premium fashion 
                    that combines quality, style, and convenience in one place.
                </p>
                <p class="mb-4">
                    What started as a small boutique has grown into a trusted fashion destination, 
                    serving thousands of satisfied customers nationwide. We believe that everyone deserves 
                    access to quality clothing that makes them feel confident and comfortable.
                </p>
                <p class="mb-0">
                    Our journey is built on three pillars: <strong>Quality</strong>, <strong>Style</strong>, 
                    and <strong>Customer Satisfaction</strong>. These principles guide everything we do.
                </p>
            </div>
            <div class="col-lg-6">
                <img src="{{ asset('images/about-story.jpg') }}" alt="Our Story" class="img-fluid rounded shadow">
            </div>
        </div>
    </div>
</section>

<!-- Mission & Vision -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="text-center mb-4">
                            <i class="bi bi-bullseye display-4 text-primary"></i>
                        </div>
                        <h3 class="card-title text-center mb-3">Our Mission</h3>
                        <p class="card-text text-center">
                            To provide premium fashion solutions that empower individuals to express their 
                            unique style with confidence and comfort.
                        </p>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-6 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="text-center mb-4">
                            <i class="bi bi-eye display-4 text-success"></i>
                        </div>
                        <h3 class="card-title text-center mb-3">Our Vision</h3>
                        <p class="card-text text-center">
                            To become the leading fashion destination known for exceptional quality, 
                            curated style, and unparalleled customer experience.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Values -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Our Values</h2>
            <p class="text-muted">The principles that guide everything we do</p>
        </div>
        
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center p-4">
                        <div class="icon-wrapper bg-primary rounded-circle p-3 mb-3 mx-auto">
                            <i class="bi bi-award text-white fs-3"></i>
                        </div>
                        <h4 class="card-title">Quality First</h4>
                        <p class="card-text text-muted">
                            We never compromise on quality. Every product is carefully selected and 
                            inspected to meet our high standards.
                        </p>
                    </div>
                </div>
            </div>
            
            <div class="col-md-4 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center p-4">
                        <div class="icon-wrapper bg-success rounded-circle p-3 mb-3 mx-auto">
                            <i class="bi bi-heart text-white fs-3"></i>
                        </div>
                        <h4 class="card-title">Customer Focus</h4>
                        <p class="card-text text-muted">
                            Your satisfaction is our priority. We listen to feedback and continuously 
                            improve our services to serve you better.
                        </p>
                    </div>
                </div>
            </div>
            
            <div class="col-md-4 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center p-4">
                        <div class="icon-wrapper bg-warning rounded-circle p-3 mb-3 mx-auto">
                            <i class="bi bi-lightbulb text-white fs-3"></i>
                        </div>
                        <h4 class="card-title">Innovation</h4>
                        <p class="card-text text-muted">
                            We embrace change and innovation to bring you the latest fashion trends 
                            and convenient shopping experiences.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Team -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Meet Our Team</h2>
            <p class="text-muted">The talented people behind SMSol Studio</p>
        </div>
        
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card border-0 shadow-sm text-center">
                    <div class="card-body p-4">
                        <div class="team-image mx-auto mb-3">
                            <img src="https://via.placeholder.com/150" alt="Team Member" class="rounded-circle">
                        </div>
                        <h4 class="card-title mb-1">Sarah Johnson</h4>
                        <p class="text-muted mb-3">Founder & CEO</p>
                        <p class="card-text small">
                            With over 10 years in fashion retail, Sarah leads our vision and strategy.
                        </p>
                    </div>
                </div>
            </div>
            
            <div class="col-md-4 mb-4">
                <div class="card border-0 shadow-sm text-center">
                    <div class="card-body p-4">
                        <div class="team-image mx-auto mb-3">
                            <img src="https://via.placeholder.com/150" alt="Team Member" class="rounded-circle">
                        </div>
                        <h4 class="card-title mb-1">Michael Chen</h4>
                        <p class="text-muted mb-3">Head of Operations</p>
                        <p class="card-text small">
                            Michael ensures smooth operations and excellent customer service.
                        </p>
                    </div>
                </div>
            </div>
            
            <div class="col-md-4 mb-4">
                <div class="card border-0 shadow-sm text-center">
                    <div class="card-body p-4">
                        <div class="team-image mx-auto mb-3">
                            <img src="https://via.placeholder.com/150" alt="Team Member" class="rounded-circle">
                        </div>
                        <h4 class="card-title mb-1">Emily Rodriguez</h4>
                        <p class="text-muted mb-3">Fashion Director</p>
                        <p class="card-text small">
                            Emily curates our collection with an eye for style and quality.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stats -->
<section class="py-5">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-3">
                <h2 class="display-4 fw-bold text-primary">4+</h2>
                <p class="text-muted">Years Experience</p>
            </div>
            <div class="col-md-3">
                <h2 class="display-4 fw-bold text-primary">2K+</h2>
                <p class="text-muted">Happy Customers</p>
            </div>
            <div class="col-md-3">
                <h2 class="display-4 fw-bold text-primary">500+</h2>
                <p class="text-muted">Products</p>
            </div>
            <div class="col-md-3">
                <h2 class="display-4 fw-bold text-primary">50+</h2>
                <p class="text-muted">Brand Partners</p>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="py-5 bg-primary text-white">
    <div class="container text-center">
        <h2 class="fw-bold mb-3">Ready to Experience Quality Fashion?</h2>
        <p class="lead mb-4 opacity-75">Join our community of fashion enthusiasts today.</p>
        <div class="d-flex justify-content-center gap-3">
            <a href="{{ path('app_register') }}" class="btn btn-light btn-lg px-5">
                <i class="bi bi-person-plus me-2"></i>Join Now
            </a>
            <a href="{{ path('app_contact') }}" class="btn btn-outline-light btn-lg px-5">
                <i class="bi bi-chat-dots me-2"></i>Contact Us
            </a>
        </div>
    </div>
</section>
{% endblock %}