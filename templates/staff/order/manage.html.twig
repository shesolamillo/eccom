{% extends 'layouts/admin.html.twig' %}

{% block title %}Manage Order - Staff{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('staff_orders') }}">Orders</a></li>
<li class="breadcrumb-item active">Order #{{ order.orderNumber }}</li>
{% endblock %}

{% block page_title %}Order #{{ order.orderNumber }}{% endblock %}
{% block page_description %}Manage and process this customer order{% endblock %}

{% block admin_content %}
<div class="row">
    <!-- Order Items (Shopping Cart Style) -->
    <div class="col-lg-8">
        <div class="card admin-chart">
            <div class="card-header bg-white border-0">
                <h5 class="mb-0"><i class="bi bi-bag-check me-2"></i>Order Items</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th class="text-center">Price</th>
                                <th class="text-center">Quantity</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% if order.orderItems|length > 0 %}
                                {% for item in order.orderItems %}
                                    <tr>
                                        <td class="py-3">
                                            <div class="d-flex align-items-center">
                                                {% if item.product.photoUrl %}
                                                    <img src="{{ item.product.photoUrl }}" 
                                                         alt="{{ item.product.name }}"
                                                         class="rounded me-3"
                                                         style="width: 60px; height: 60px; object-fit: cover;">
                                                {% else %}
                                                    <div class="bg-light rounded me-3 d-flex align-items-center justify-content-center"
                                                         style="width: 60px; height: 60px;">
                                                        <i class="bi bi-image"></i>
                                                    </div>
                                                {% endif %}
                                                <div>
                                                    <h6 class="mb-1">{{ item.product.name }}</h6>
                                                    <small class="text-muted">Stock: {{ item.product.stock.quantity }}</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center py-3">
                                            <strong>₱{{ item.unitPrice|number_format(2) }}</strong>
                                        </td>
                                        <td class="text-center py-3">
                                            <span class="badge bg-light text-dark">{{ item.quantity }}</span>
                                        </td>
                                        <td class="text-end py-3">
                                            <strong>₱{{ item.total|number_format(2) }}</strong>
                                        </td>
                                    </tr>
                                {% endfor %}
                            {% else %}
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted">
                                        No items in order
                                    </td>
                                </tr>
                            {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Customer Details -->
        <div class="card admin-chart mt-3">
            <div class="card-header bg-white border-0">
                <h5 class="mb-0">Customer Details</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <p class="mb-1"><strong>Customer:</strong></p>
                        <p class="text-muted mb-3">{{ order.customer.firstName }} {{ order.customer.lastName }}</p>
                        <p class="mb-1"><strong>Email:</strong></p>
                        <p class="text-muted">{{ order.customer.email }}</p>
                    </div>
                    <div class="col-md-6">
                        <p class="mb-1"><strong>Delivery Type:</strong></p>
                        <p class="text-muted mb-3">{{ order.deliveryType|capitalize }}</p>
                        {% if order.deliveryAddress %}
                            <p class="mb-1"><strong>Address:</strong></p>
                            <p class="text-muted">{{ order.deliveryAddress }}</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Order Summary & Actions -->
    <div class="col-lg-4">
        <div class="card admin-chart">
            <div class="card-header bg-white border-0">
                <h5 class="mb-0">Order Summary</h5>
            </div>
            <div class="card-body">
                <!-- Status Badge -->
                <div class="mb-3 pb-3 border-bottom">
                    <p class="mb-2"><strong>Current Status:</strong></p>
                    {% if order.status == 'pending' %}
                        <span class="badge bg-warning">{{ order.status|capitalize }}</span>
                    {% elseif order.status == 'accepted' %}
                        <span class="badge bg-info">{{ order.status|capitalize }}</span>
                    {% elseif order.status == 'processing' %}
                        <span class="badge bg-primary">{{ order.status|capitalize }}</span>
                    {% elseif order.status == 'completed' %}
                        <span class="badge bg-success">{{ order.status|capitalize }}</span>
                    {% else %}
                        <span class="badge bg-danger">{{ order.status|capitalize }}</span>
                    {% endif %}
                </div>

                <!-- Pricing -->
                <div class="mb-2">
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Subtotal</span>
                        <span>₱{{ order.total|number_format(2) }}</span>
                    </div>
                </div>

                <div class="mb-2">
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Delivery Fee</span>
                        <span>₱{{ order.deliveryFee|number_format(2) }}</span>
                    </div>
                </div>

                <div class="mb-3 pb-3 border-bottom">
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Discount</span>
                        <span class="text-success">₱0.00</span>
                    </div>
                </div>

                <!-- Total -->
                <div class="mb-4">
                    <div class="d-flex justify-content-between">
                        <span class="h5 mb-0">Total Amount</span>
                        <span class="h5 mb-0 text-primary">₱{{ (order.total + order.deliveryFee)|number_format(2) }}</span>
                    </div>
                </div>

                <!-- Payment Status -->
                <div class="mb-3 pb-3 border-bottom">
                    <p class="mb-2"><strong>Payment Status:</strong></p>
                    {% if order.isPaid %}
                        <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Paid</span>
                    {% else %}
                        <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Unpaid</span>
                    </span>
                </div>

                <!-- Quick Actions -->
                <div class="d-grid gap-2">
                    {% if order.status == 'pending' %}
                        <form action="{{ path('staff_order_manage', {'id': order.id}) }}" method="POST" style="display:inline;">
                            <input type="hidden" name="status" value="accepted">
                            <button type="submit" class="btn btn-success w-100 btn-sm">
                                <i class="bi bi-check-circle me-2"></i>Accept Order
                            </button>
                        </form>
                    {% elseif order.status == 'accepted' %}
                        <form action="{{ path('staff_order_manage', {'id': order.id}) }}" method="POST" style="display:inline;">
                            <input type="hidden" name="status" value="processing">
                            <button type="submit" class="btn btn-info w-100 btn-sm text-white">
                                <i class="bi bi-gear me-2"></i>Start Processing
                            </button>
                        </form>
                    {% elseif order.status == 'processing' %}
                        <form action="{{ path('staff_order_manage', {'id': order.id}) }}" method="POST" style="display:inline;">
                            <input type="hidden" name="status" value="completed">
                            <button type="submit" class="btn btn-success w-100 btn-sm">
                                <i class="bi bi-check-all me-2"></i>Mark Completed
                            </button>
                        </form>
                    {% endif %}
                    
                    <a href="{{ path('staff_orders') }}" class="btn btn-secondary btn-sm">
                        <i class="bi bi-arrow-left me-2"></i>Back to Orders
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
