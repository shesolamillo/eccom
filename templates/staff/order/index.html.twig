{% extends 'layouts/admin.html.twig' %}

{% block title %}Orders - Staff{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('admin_dashboard') }}">Dashboard</a></li>
<li class="breadcrumb-item active">Orders</li>
{% endblock %}

{% block page_title %}Staff Orders{% endblock %}
{% block page_description %}Manage and process customer orders{% endblock %}

{% block page_actions %}
<div class="d-flex gap-2">
    <div class="btn-group" role="group">
        <input type="radio" class="btn-check" name="status-filter" id="all-status" value="" checked>
        <label class="btn btn-outline-primary" for="all-status">All</label>

        <input type="radio" class="btn-check" name="status-filter" id="pending-status" value="pending">
        <label class="btn btn-outline-warning" for="pending-status">Pending</label>

        <input type="radio" class="btn-check" name="status-filter" id="accepted-status" value="accepted">
        <label class="btn btn-outline-info" for="accepted-status">Accepted</label>

        <input type="radio" class="btn-check" name="status-filter" id="processing-status" value="processing">
        <label class="btn btn-outline-primary" for="processing-status">Processing</label>

        <input type="radio" class="btn-check" name="status-filter" id="completed-status" value="completed">
        <label class="btn btn-outline-success" for="completed-status">Completed</label>
    </div>
</div>
{% endblock %}

{% block admin_content %}
{% if orders is empty %}
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>No orders found.
    </div>
{% else %}
    <div class="row">
        <!-- Order Stats -->
        <div class="col-md-3 mb-4">
            <div class="card admin-chart text-center">
                <div class="card-body">
                    <div class="display-6 text-primary mb-2">{{ orders|length }}</div>
                    <p class="text-muted mb-0">Total Orders</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Orders Table -->
    <div class="card admin-chart">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Order #</th>
                            <th>Customer</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Payment</th>
                            <th>Date</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for order in orders %}
                            <tr>
                                <td class="fw-600">{{ order.orderNumber }}</td>
                                <td>
                                    <small>{{ order.customer.firstName }} {{ order.customer.lastName }}</small><br>
                                    <small class="text-muted">{{ order.customer.email }}</small>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark">{{ order.orderItems|length }} items</span>
                                </td>
                                <td>
                                    <strong>₱{{ (order.total + order.deliveryFee)|number_format(2) }}</strong>
                                </td>
                                <td>
                                    {% if order.status == 'pending' %}
                                        <span class="badge bg-warning">{{ order.status|capitalize }}</span>
                                    {% elseif order.status == 'accepted' %}
                                        <span class="badge bg-info">{{ order.status|capitalize }}</span>
                                    {% elseif order.status == 'processing' %}
                                        <span class="badge bg-primary">{{ order.status|capitalize }}</span>
                                    {% elseif order.status == 'completed' %}
                                        <span class="badge bg-success">{{ order.status|capitalize }}</span>
                                    {% else %}
                                        <span class="badge bg-danger">{{ order.status|capitalize }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if order.isPaid %}
                                        <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Paid</span>
                                    {% else %}
                                        <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Unpaid</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <small>{{ order.createdAt|date('M d, Y') }}</small>
                                </td>
                                <td class="text-center">
                                    <a href="{{ path('staff_order_manage', {'id': order.id}) }}" 
                                       class="btn btn-sm btn-outline-primary" 
                                       title="View & Manage">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endif %}

<!-- Filtering Script -->
<script>
document.querySelectorAll('input[name="status-filter"]').forEach(radio => {
    radio.addEventListener('change', function() {
        // Filter implementation - trigger server-side filter or client-side
        const status = this.value;
        // Could add AJAX filtering here
        console.log('Filter by status:', status);
    });
});
</script>
{% endblock %}
