{# templates/order/staff/manage.html.twig #}
{% extends 'layouts/admin.html.twig' %}

{% block title %}Manage Order #{{ order.orderNumber }} - SMSol Studio{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('staff_orders') }}">Orders</a></li>
<li class="breadcrumb-item active">Order #{{ order.orderNumber }}</li>
{% endblock %}

{% block page_title %}Manage Order <span class="text-primary">#{{ order.orderNumber }}</span>{% endblock %}
{% block page_description %}{{ order.createdAt|date('F j, Y h:i A') }} | {{ order.customer.fullName|default('Customer') }}{% endblock %}

{% block page_actions %}
<div class="btn-group">
    <button type="button" class="btn btn-success" onclick="markAsCompleted()">
        <i class="bi bi-check-circle me-2"></i>Mark as Completed
    </button>
    <button type="button" class="btn btn-danger" onclick="cancelOrder()">
        <i class="bi bi-x-circle me-2"></i>Cancel Order
    </button>
</div>
{% endblock %}

{% block admin_content %}
<div class="row">
    <div class="col-lg-8">
        <!-- Order Status Card -->
        <div class="card admin-chart mb-4">
            <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Order Status</h5>
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" 
                            data-bs-toggle="dropdown" aria-expanded="false">
                        Change Status
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#" onclick="updateStatus('pending')">
                            <span class="badge bg-warning me-2">●</span>Pending
                        </a></li>
                        <li><a class="dropdown-item" href="#" onclick="updateStatus('processing')">
                            <span class="badge bg-info me-2">●</span>Processing
                        </a></li>
                        <li><a class="dropdown-item" href="#" onclick="updateStatus('completed')">
                            <span class="badge bg-success me-2">●</span>Completed
                        </a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="#" onclick="updateStatus('cancelled')">
                            <span class="badge bg-danger me-2">●</span>Cancel Order
                        </a></li>
                    </ul>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="order-status-timeline">
                            <div class="status-step {{ order.status == 'pending' or order.status == 'processing' or order.status == 'completed' ? 'completed' : '' }}">
                                <div class="step-icon">
                                    <i class="bi bi-cart"></i>
                                </div>
                                <div class="step-content">
                                    <h6>Order Placed</h6>
                                    <p class="text-muted small">{{ order.createdAt|date('M d, Y h:i A') }}</p>
                                </div>
                            </div>
                            
                            <div class="status-step {{ order.status == 'processing' or order.status == 'completed' ? 'completed' : '' }}">
                                <div class="step-icon">
                                    <i class="bi bi-gear"></i>
                                </div>
                                <div class="step-content">
                                    <h6>Processing</h6>
                                    <p class="text-muted small">
                                        {% if order.status == 'processing' or order.status == 'completed' %}
                                            {{ order.updatedAt|default('In progress')|date('M d, Y h:i A') }}
                                        {% else %}
                                            Pending
                                        {% endif %}
                                    </p>
                                </div>
                            </div>
                            
                            <div class="status-step {{ order.status == 'completed' ? 'completed' : '' }}">
                                <div class="step-icon">
                                    <i class="bi bi-check-circle"></i>
                                </div>
                                <div class="step-content">
                                    <h6>Completed</h6>
                                    <p class="text-muted small">
                                        {% if order.completedAt %}
                                            {{ order.completedAt|date('M d, Y h:i A') }}
                                        {% else %}
                                            Pending
                                        {% endif %}
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-md-6">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6>Current Status</h6>
                                <div class="d-flex align-items-center mb-3">
                                    <span class="badge {{ order.status == 'pending' ? 'bg-warning' : (order.status == 'processing' ? 'bg-info' : (order.status == 'completed' ? 'bg-success' : 'bg-danger')) }} fs-6 px-3 py-2">
                                        {{ order.status|upper }}
                                    </span>
                                    {% if order.isUrgent %}
                                    <span class="badge bg-danger ms-2">
                                        <i class="bi bi-exclamation-triangle me-1"></i>URGENT
                                    </span>
                                    {% endif %}
                                </div>
                                
                                <div class="row g-2">
                                    <div class="col-6">
                                        <small class="text-muted">Payment</small>
                                        <p class="mb-0">
                                            <span class="badge {{ order.isPaid ? 'bg-success' : 'bg-warning' }}">
                                                {{ order.isPaid ? 'PAID' : 'UNPAID' }}
                                            </span>
                                            {% if order.paidAt %}
                                                <br><small class="text-muted">{{ order.paidAt|date('M d, Y') }}</small>
                                            {% endif %}
                                        </p>
                                    </div>
                                    <div class="col-6">
                                        <small class="text-muted">Delivery Type</small>
                                        <p class="mb-0">
                                            <span class="badge {{ order.deliveryType == 'delivery' ? 'bg-primary' : 'bg-secondary' }}">
                                                {{ order.deliveryType|upper }}
                                            </span>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Order Items Card -->
        <div class="card admin-chart mb-4">
            <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Order Items</h5>
                <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addItemModal">
                    <i class="bi bi-plus-circle me-1"></i>Add Item
                </button>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th>Product</th>
                                <th>Price</th>
                                <th>Quantity</th>
                                <th>Total</th>
                                <th>Stock</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in order.orderItems %}
                            <tr id="order-item-{{ item.id }}">
                                <td>
                                    <div>
                                        <strong>{{ item.product.name|default('Unknown Product') }}</strong>
                                        {% if item.product.description %}
                                        <div class="text-muted small">{{ item.product.description|slice(0, 50) }}...</div>
                                        {% endif %}
                                        <div class="text-muted small">SKU: {{ item.product.sku|default('N/A') }}</div>
                                    </div>
                                </td>
                                <td>₱{{ item.price|number_format(2) }}</td>
                                <td>
                                    <div class="input-group input-group-sm" style="width: 140px;">
                                        <button class="btn btn-outline-secondary" type="button" 
                                                onclick="updateQuantity({{ item.id }}, -1)">
                                            <i class="bi bi-dash"></i>
                                        </button>
                                        <input type="number" class="form-control text-center" 
                                               id="quantity-{{ item.id }}"
                                               value="{{ item.quantity }}" 
                                               min="1" 
                                               onchange="updateQuantityDirect({{ item.id }}, this.value)">
                                        <button class="btn btn-outline-secondary" type="button" 
                                                onclick="updateQuantity({{ item.id }}, 1)">
                                            <i class="bi bi-plus"></i>
                                        </button>
                                    </div>
                                </td>
                                <td class="fw-bold">₱{{ item.totalPrice|number_format(2) }}</td>
                                <td>
                                    {% if item.product.stock %}
                                        <span class="badge {{ item.product.stock.quantity > 10 ? 'bg-success' : (item.product.stock.quantity > 0 ? 'bg-warning' : 'bg-danger') }}">
                                            {{ item.product.stock.quantity }} in stock
                                        </span>
                                    {% else %}
                                        <span class="badge bg-secondary">N/A</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button type="button" class="btn btn-outline-info" 
                                                onclick="editItemPrice({{ item.id }}, {{ item.price }})"
                                                title="Edit Price">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button type="button" class="btn btn-outline-danger" 
                                                onclick="removeItem({{ item.id }}, '{{ item.product.name|e('js') }}')"
                                                title="Remove Item">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            {% else %}
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="bi bi-cart-x fs-1"></i>
                                    <p class="mt-2">No items in this order</p>
                                    <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addItemModal">
                                        <i class="bi bi-plus-circle me-1"></i>Add First Item
                                    </button>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                        <tfoot class="bg-light">
                            <tr>
                                <td colspan="3" class="text-end"><strong>Subtotal:</strong></td>
                                <td colspan="3"><strong>₱{{ order.totalAmount - order.deliveryFee|default(0) }}</strong></td>
                            </tr>
                            {% if order.deliveryFee > 0 %}
                            <tr>
                                <td colspan="3" class="text-end"><strong>Delivery Fee:</strong></td>
                                <td colspan="3">₱{{ order.deliveryFee|number_format(2) }}</td>
                            </tr>
                            {% endif %}
                            <tr>
                                <td colspan="3" class="text-end"><h5 class="mb-0">Total Amount:</h5></td>
                                <td colspan="3"><h5 class="mb-0 text-primary">₱{{ order.totalAmount|number_format(2) }}</h5></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
        
        <!-- Order Details Card -->
        <div class="card admin-chart">
            <div class="card-header bg-white border-0">
                <h5 class="mb-0">Order Details</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6>Customer Information</h6>
                        <table class="table table-sm">
                            <tr>
                                <th width="40%">Name:</th>
                                <td>{{ order.customer.fullName|default('N/A') }}</td>
                            </tr>
                            <tr>
                                <th>Email:</th>
                                <td>{{ order.customer.email|default('N/A') }}</td>
                            </tr>
                            <tr>
                                <th>Phone:</th>
                                <td>{{ order.customer.phoneNumber|default('N/A') }}</td>
                            </tr>
                            {% if order.deliveryAddress %}
                            <tr>
                                <th>Delivery Address:</th>
                                <td>{{ order.deliveryAddress }}</td>
                            </tr>
                            {% endif %}
                            <tr>
                                <th>Customer Since:</th>
                                <td>{{ order.customer.createdAt|default('N/A')|date('M d, Y') }}</td>
                            </tr>
                            <tr>
                                <th>Total Orders:</th>
                                <td>{{ order.customer.orders|length|default(0) }}</td>
                            </tr>
                        </table>
                    </div>
                    
                    <div class="col-md-6">
                        <h6>Order Information</h6>
                        <table class="table table-sm">
                            <tr>
                                <th width="40%">Order Date:</th>
                                <td>{{ order.createdAt|date('F j, Y h:i A') }}</td>
                            </tr>
                            <tr>
                                <th>Payment Method:</th>
                                <td>
                                    <span class="badge {{ order.paymentMethod == 'cash' ? 'bg-success' : 'bg-primary' }}">
                                        {{ order.paymentMethod|upper }}
                                    </span>
                                </td>
                            </tr>
                            <tr>
                                <th>Delivery Type:</th>
                                <td>
                                    <span class="badge {{ order.deliveryType == 'delivery' ? 'bg-primary' : 'bg-secondary' }}">
                                        {{ order.deliveryType|upper }}
                                    </span>
                                </td>
                            </tr>
                            {% if order.pickupDate %}
                            <tr>
                                <th>Pickup Date:</th>
                                <td>{{ order.pickupDate|date('F j, Y h:i A') }}</td>
                            </tr>
                            {% endif %}
                            {% if order.deliveryDate %}
                            <tr>
                                <th>Delivery Date:</th>
                                <td>{{ order.deliveryDate|date('F j, Y h:i A') }}</td>
                            </tr>
                            {% endif %}
                            {% if order.processedBy %}
                            <tr>
                                <th>Processed By:</th>
                                <td>{{ order.processedBy.fullName }}</td>
                            </tr>
                            {% endif %}
                            <tr>
                                <th>Created By:</th>
                                <td>{{ order.createdBy.fullName|default('System') }}</td>
                            </tr>
                        </table>
                    </div>
                </div>
                
                {% if order.notes %}
                <div class="row mt-3">
                    <div class="col-12">
                        <h6>Order Notes</h6>
                        <div class="card bg-light">
                            <div class="card-body">
                                {{ order.notes|nl2br }}
                            </div>
                        </div>
                    </div>
                </div>
                {% endif %}
                
                <!-- Order Notes Editor -->
                <div class="row mt-4">
                    <div class="col-12">
                        <h6>Add/Update Notes</h6>
                        <div class="mb-3">
                            <textarea class="form-control" id="orderNotes" rows="3" placeholder="Add or update order notes...">{{ order.notes }}</textarea>
                            <div class="form-text">These notes are visible to staff only</div>
                        </div>
                        <button type="button" class="btn btn-sm btn-primary" onclick="updateOrderNotes()">
                            <i class="bi bi-save me-1"></i>Save Notes
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Right Sidebar - Actions -->
    <div class="col-lg-4">
        <!-- Order Actions Card -->
        <div class="card admin-chart mb-4">
            <div class="card-header bg-white border-0">
                <h5 class="mb-0">Order Actions</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    {% if not order.isPaid %}
                    <button type="button" class="btn btn-success" onclick="markAsPaid()">
                        <i class="bi bi-cash-coin me-2"></i>Mark as Paid
                    </button>
                    {% else %}
                    <button type="button" class="btn btn-warning" onclick="markAsUnpaid()">
                        <i class="bi bi-x-circle me-2"></i>Mark as Unpaid
                    </button>
                    {% endif %}
                    
                    <button type="button" class="btn btn-primary" onclick="generateReceipt()">
                        <i class="bi bi-receipt me-2"></i>Generate Receipt
                    </button>
                    
                    <button type="button" class="btn btn-info" onclick="sendNotification()">
                        <i class="bi bi-bell me-2"></i>Send Update to Customer
                    </button>
                    
                    <a href="{{ path('staff_order_new') }}?customer={{ order.customer.id }}" 
                       class="btn btn-outline-primary">
                        <i class="bi bi-plus-circle me-2"></i>New Order for Same Customer
                    </a>
                    
                    <button type="button" class="btn btn-outline-danger" onclick="deleteOrder()">
                        <i class="bi bi-trash me-2"></i>Delete Order
                    </button>
                </div>
                
                <hr class="my-4">
                
                <!-- Payment Status -->
                <div class="mb-3">
                    <label class="form-label">Payment Status</label>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" role="switch" 
                               id="paymentStatus" {{ order.isPaid ? 'checked' : '' }} 
                               onchange="togglePaymentStatus()">
                        <label class="form-check-label" for="paymentStatus">
                            {{ order.isPaid ? 'Paid' : 'Unpaid' }}
                        </label>
                    </div>
                    {% if order.paidAt %}
                    <small class="text-muted d-block">Paid on {{ order.paidAt|date('M d, Y h:i A') }}</small>
                    {% endif %}
                </div>
                
                <!-- Delivery/Pickup Date -->
                <div class="mb-3">
                    <label class="form-label">{{ order.deliveryType == 'delivery' ? 'Delivery' : 'Pickup' }} Date</label>
                    <input type="datetime-local" class="form-control" 
                           id="scheduledDate" 
                           value="{{ (order.deliveryType == 'delivery' ? order.deliveryDate : order.pickupDate)|date('Y-m-d\\TH:i') }}">
                    <div class="d-flex gap-2 mt-2">
                        <button type="button" class="btn btn-sm btn-primary flex-grow-1" 
                                onclick="updateScheduledDate()">
                            Update Date
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" 
                                onclick="clearScheduledDate()">
                            Clear
                        </button>
                    </div>
                </div>
                
                <!-- Mark as Urgent -->
                <div class="mb-3">
                    <label class="form-label">Urgent Order</label>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" role="switch" 
                               id="urgentStatus" {{ order.isUrgent ? 'checked' : '' }} 
                               onchange="toggleUrgentStatus()">
                        <label class="form-check-label" for="urgentStatus">
                            {{ order.isUrgent ? 'Urgent' : 'Normal' }}
                        </label>
                    </div>
                    <small class="text-muted">Urgent orders require priority handling</small>
                </div>
            </div>
        </div>
        
        <!-- Quick Stats -->
        <div class="card admin-chart mb-4">
            <div class="card-header bg-white border-0">
                <h5 class="mb-0">Order Summary</h5>
            </div>
            <div class="card-body">
                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <div class="bg-light p-3 rounded text-center">
                            <h6 class="text-muted mb-1">Items</h6>
                            <h3 class="fw-bold mb-0">{{ order.orderItems|length }}</h3>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="bg-light p-3 rounded text-center">
                            <h6 class="text-muted mb-1">Total</h6>
                            <h3 class="fw-bold mb-0">₱{{ order.totalAmount|number_format(2) }}</h3>
                        </div>
                    </div>
                </div>
                
                <table class="table table-sm table-borderless">
                    <tr>
                        <td>Subtotal:</td>
                        <td class="text-end">₱{{ (order.totalAmount - order.deliveryFee|default(0))|number_format(2) }}</td>
                    </tr>
                    {% if order.deliveryFee > 0 %}
                    <tr>
                        <td>Delivery Fee:</td>
                        <td class="text-end">₱{{ order.deliveryFee|number_format(2) }}</td>
                    </tr>
                    {% endif %}
                    <tr>
                        <th>Total:</th>
                        <th class="text-end text-primary">₱{{ order.totalAmount|number_format(2) }}</th>
                    </tr>
                </table>
                
                <hr class="my-4">
                
                <h6 class="mb-3">Timeline</h6>
                <ul class="list-unstyled timeline">
                    <li class="mb-3">
                        <i class="bi bi-cart text-primary me-2"></i>
                        <span>Order Created</span>
                        <small class="text-muted d-block">{{ order.createdAt|date('M d, h:i A') }}</small>
                    </li>
                    {% if order.updatedAt and order.updatedAt != order.createdAt %}
                    <li class="mb-3">
                        <i class="bi bi-pencil text-warning me-2"></i>
                        <span>Last Updated</span>
                        <small class="text-muted d-block">{{ order.updatedAt|date('M d, h:i A') }}</small>
                    </li>
                    {% endif %}
                    {% if order.completedAt %}
                    <li class="mb-3">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <span>Completed</span>
                        <small class="text-muted d-block">{{ order.completedAt|date('M d, h:i A') }}</small>
                    </li>
                    {% endif %}
                    {% if order.paidAt %}
                    <li class="mb-3">
                        <i class="bi bi-cash-coin text-success me-2"></i>
                        <span>Payment Received</span>
                        <small class="text-muted d-block">{{ order.paidAt|date('M d, h:i A') }}</small>
                    </li>
                    {% endif %}
                </ul>
            </div>
        </div>
        
        <!-- Customer Stats -->
        <div class="card admin-chart">
            <div class="card-header bg-white border-0">
                <h5 class="mb-0">Customer Information</h5>
            </div>
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="flex-shrink-0">
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" 
                             style="width: 50px; height: 50px; font-size: 1.25rem;">
                            {{ order.customer.fullName|first|upper }}
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mb-0">{{ order.customer.fullName|default('Customer') }}</h6>
                        <small class="text-muted">{{ order.customer.email|default('No email') }}</small>
                    </div>
                </div>
                
                <table class="table table-sm table-borderless">
                    <tr>
                        <td>Phone:</td>
                        <td class="text-end">{{ order.customer.phoneNumber|default('N/A') }}</td>
                    </tr>
                    <tr>
                        <td>Member Since:</td>
                        <td class="text-end">{{ order.customer.createdAt|date('M d, Y') }}</td>
                    </tr>
                    <tr>
                        <td>Total Orders:</td>
                        <td class="text-end">
                            <span class="badge bg-info">{{ order.customer.orders|length|default(0) }}</span>
                        </td>
                    </tr>
                    <tr>
                        <td>Total Spent:</td>
                        <td class="text-end fw-bold">
                            ₱{{ order.customer.orders|reduce((total, o) => total + o.totalAmount, 0)|number_format(2) }}
                        </td>
                    </tr>
                </table>
                
                <div class="d-grid gap-2 mt-3">
                    <a href="{{ path('admin_user_edit', {'id': order.customer.id}) }}" 
                       class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-person me-1"></i>View Customer Profile
                    </a>
                    <a href="{{ path('staff_orders') }}?search={{ order.customer.email }}" 
                       class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-list me-1"></i>View All Orders
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Item Modal -->
<div class="modal fade" id="addItemModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Product to Order</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Select Product *</label>
                    <select class="form-select" id="productSelect" required>
                        <option value="">Choose a product...</option>
                        {% for product in availableProducts %}
                        <option value="{{ product.id }}" 
                                data-price="{{ product.price }}" 
                                data-stock="{{ product.stock.quantity|default(0) }}"
                                data-name="{{ product.name }}">
                            {{ product.name }} - ₱{{ product.price|number_format(2) }} 
                            (Stock: {{ product.stock.quantity|default(0) }})
                        </option>
                        {% endfor %}
                    </select>
                    <div class="form-text">Only available products are shown</div>
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Quantity *</label>
                    <input type="number" class="form-control" id="productQuantity" 
                           min="1" value="1" max="1" required>
                    <div class="form-text">Available stock: <span id="availableStock" class="fw-bold">0</span></div>
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Price (₱) *</label>
                    <div class="input-group">
                        <span class="input-group-text">₱</span>
                        <input type="number" class="form-control" id="productPrice" 
                               min="0" step="0.01" value="0.00" required>
                    </div>
                    <div class="form-text">Default price: ₱<span id="defaultPrice">0.00</span></div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="addItemToOrder()">
                    <i class="bi bi-plus-circle me-1"></i>Add to Order
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Price Modal -->
<div class="modal fade" id="editPriceModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Item Price</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Product</label>
                    <input type="text" class="form-control" id="editProductName" readonly>
                </div>
                <div class="mb-3">
                    <label class="form-label">New Price (₱) *</label>
                    <div class="input-group">
                        <span class="input-group-text">₱</span>
                        <input type="number" class="form-control" id="editProductPrice" 
                               min="0" step="0.01" required>
                    </div>
                </div>
                <input type="hidden" id="editItemId">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveItemPrice()">Save Price</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
// Global variables
let currentItemId = null;

// Update status functions
function updateStatus(status) {
    if (confirm(`Change order status to ${status.toUpperCase()}?`)) {
        fetch(`/staff/orders/{{ order.id }}/status`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-Token': '{{ csrf_token('update-status') }}'
            },
            body: JSON.stringify({ status: status })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert('Error: ' + data.message);
            }
        })
        .catch(error => {
            alert('Error updating status: ' + error.message);
        });
    }
}

function markAsCompleted() {
    updateStatus('completed');
}

function cancelOrder() {
    if (confirm('Are you sure you want to cancel this order? This action cannot be undone.')) {
        updateStatus('cancelled');
    }
}

// Payment status
function togglePaymentStatus() {
    const isPaid = document.getElementById('paymentStatus').checked;
    updatePaymentStatus(isPaid);
}

function markAsPaid() {
    document.getElementById('paymentStatus').checked = true;
    updatePaymentStatus(true);
}

function markAsUnpaid() {
    document.getElementById('paymentStatus').checked = false;
    updatePaymentStatus(false);
}

function updatePaymentStatus(isPaid) {
    fetch(`/staff/orders/{{ order.id }}/payment`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': '{{ csrf_token('update-payment') }}'
        },
        body: JSON.stringify({ isPaid: isPaid })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert('Error: ' + data.message);
        }
    })
    .catch(error => {
        alert('Error updating payment status: ' + error.message);
    });
}

// Urgent status
function toggleUrgentStatus() {
    const isUrgent = document.getElementById('urgentStatus').checked;
    
    fetch(`/staff/orders/{{ order.id }}/urgent`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': '{{ csrf_token('update-urgent') }}'
        },
        body: JSON.stringify({ isUrgent: isUrgent })
    })
    .then(response => response.json())
    .then(data => {
        if (!data.success) {
            alert('Error: ' + data.message);
            location.reload();
        }
    })
    .catch(error => {
        alert('Error updating urgent status: ' + error.message);
        location.reload();
    });
}

// Update scheduled date
function updateScheduledDate() {
    const dateInput = document.getElementById('scheduledDate');
    const dateValue = dateInput.value;
    
    fetch(`/staff/orders/{{ order.id }}/schedule`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': '{{ csrf_token('update-schedule') }}'
        },
        body: JSON.stringify({ 
            date: dateValue,
            type: '{{ order.deliveryType }}'
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('Date updated successfully!');
            location.reload();
        } else {
            alert('Error: ' + data.message);
        }
    })
    .catch(error => {
        alert('Error updating date: ' + error.message);
    });
}

function clearScheduledDate() {
    document.getElementById('scheduledDate').value = '';
    updateScheduledDate();
}

// Order item management
function updateQuantity(itemId, change) {
    const quantityInput = document.getElementById(`quantity-${itemId}`);
    const newQuantity = parseInt(quantityInput.value) + change;
    
    if (newQuantity < 1) {
        alert('Quantity must be at least 1');
        return;
    }
    
    fetch(`/staff/orders/item/${itemId}/quantity`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': '{{ csrf_token('update-quantity') }}'
        },
        body: JSON.stringify({ change: change })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert('Error: ' + data.message);
            location.reload();
        }
    })
    .catch(error => {
        alert('Error updating quantity: ' + error.message);
        location.reload();
    });
}

function updateQuantityDirect(itemId, newQuantity) {
    if (newQuantity < 1) {
        alert('Quantity must be at least 1');
        document.getElementById(`quantity-${itemId}`).value = 1;
        return;
    }
    
    const currentQuantity = parseInt(document.getElementById(`quantity-${itemId}`).dataset.current || 0);
    const change = newQuantity - currentQuantity;
    
    if (change === 0) return;
    
    fetch(`/staff/orders/item/${itemId}/quantity`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': '{{ csrf_token('update-quantity') }}'
        },
        body: JSON.stringify({ change: change })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert('Error: ' + data.message);
            location.reload();
        }
    })
    .catch(error => {
        alert('Error updating quantity: ' + error.message);
        location.reload();
    });
}

function editItemPrice(itemId, currentPrice) {
    currentItemId = itemId;
    const itemRow = document.getElementById(`order-item-${itemId}`);
    const productName = itemRow.querySelector('strong').textContent;
    
    document.getElementById('editProductName').value = productName;
    document.getElementById('editProductPrice').value = currentPrice;
    document.getElementById('editItemId').value = itemId;
    
    new bootstrap.Modal(document.getElementById('editPriceModal')).show();
}

function saveItemPrice() {
    const newPrice = document.getElementById('editProductPrice').value;
    const itemId = document.getElementById('editItemId').value;
    
    if (!newPrice || newPrice <= 0) {
        alert('Please enter a valid price');
        return;
    }
    
    fetch(`/staff/orders/item/${itemId}/price`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': '{{ csrf_token('update-price') }}'
        },
        body: JSON.stringify({ price: newPrice })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('Price updated successfully!');
            location.reload();
        } else {
            alert('Error: ' + data.message);
        }
    })
    .catch(error => {
        alert('Error updating price: ' + error.message);
    });
}

function removeItem(itemId, productName) {
    if (confirm(`Are you sure you want to remove "${productName}" from this order?`)) {
        fetch(`/staff/orders/item/${itemId}/remove`, {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-Token': '{{ csrf_token('remove-item') }}'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert('Error: ' + data.message);
            }
        })
        .catch(error => {
            alert('Error removing item: ' + error.message);
        });
    }
}

// Add item modal functionality
document.getElementById('productSelect').addEventListener('change', function() {
    const selectedOption = this.options[this.selectedIndex];
    const price = selectedOption.getAttribute('data-price') || 0;
    const stock = selectedOption.getAttribute('data-stock') || 0;
    const productName = selectedOption.getAttribute('data-name') || '';
    
    document.getElementById('productPrice').value = parseFloat(price).toFixed(2);
    document.getElementById('defaultPrice').textContent = parseFloat(price).toFixed(2);
    document.getElementById('availableStock').textContent = stock;
    document.getElementById('productQuantity').max = stock;
    document.getElementById('productQuantity').value = Math.min(1, stock);
    
    // Update quantity input color based on stock
    const quantityInput = document.getElementById('productQuantity');
    if (stock == 0) {
        quantityInput.disabled = true;
        quantityInput.classList.add('bg-danger', 'text-white');
    } else {
        quantityInput.disabled = false;
        quantityInput.classList.remove('bg-danger', 'text-white');
    }
});

function addItemToOrder() {
    const productSelect = document.getElementById('productSelect');
    const productId = productSelect.value;
    const productName = productSelect.options[productSelect.selectedIndex]?.getAttribute('data-name') || '';
    const quantity = document.getElementById('productQuantity').value;
    const price = document.getElementById('productPrice').value;
    
    if (!productId) {
        alert('Please select a product');
        return;
    }
    
    if (quantity <= 0) {
        alert('Please enter a valid quantity');
        return;
    }
    
    if (price <= 0) {
        alert('Please enter a valid price');
        return;
    }
    
    const maxStock = parseInt(document.getElementById('productQuantity').max);
    if (quantity > maxStock) {
        alert(`Cannot add ${quantity} items. Only ${maxStock} available in stock.`);
        return;
    }
    
    fetch(`/staff/orders/{{ order.id }}/add-item`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': '{{ csrf_token('add-item') }}'
        },
        body: JSON.stringify({ 
            productId: productId,
            quantity: quantity,
            price: price
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Close modal and reload
            const modal = bootstrap.Modal.getInstance(document.getElementById('addItemModal'));
            modal.hide();
            location.reload();
        } else {
            alert('Error: ' + data.message);
        }
    })
    .catch(error => {
        alert('Error adding item: ' + error.message);
    });
}

// Update order notes
function updateOrderNotes() {
    const notes = document.getElementById('orderNotes').value;
    
    fetch(`/staff/orders/{{ order.id }}/notes`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': '{{ csrf_token('update-notes') }}'
        },
        body: JSON.stringify({ notes: notes })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('Notes updated successfully!');
            location.reload();
        } else {
            alert('Error: ' + data.message);
        }
    })
    .catch(error => {
        alert('Error updating notes: ' + error.message);
    });
}

// Other actions
function generateReceipt() {
    window.open(`/receipt/{{ order.id }}/generate`, '_blank');
}

function sendNotification() {
    fetch(`/staff/orders/{{ order.id }}/notify`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': '{{ csrf_token('send-notification') }}'
        }
    })
    .then(response => response.json())
    .then(data => {
        alert(data.message || 'Notification sent to customer!');
    })
    .catch(error => {
        alert('Error sending notification: ' + error.message);
    });
}

function deleteOrder() {
    if (confirm('Are you sure you want to delete this order? This action cannot be undone.')) {
        fetch(`/staff/orders/{{ order.id }}/delete`, {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-Token': '{{ csrf_token('delete-order') }}'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert('Order deleted successfully!');
                window.location.href = '{{ path('staff_orders') }}';
            } else {
                alert('Error: ' + data.message);
            }
        })
        .catch(error => {
            alert('Error deleting order: ' + error.message);
        });
    }
}
</script>

