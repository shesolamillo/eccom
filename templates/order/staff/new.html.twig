{# templates/order/staff/new.html.twig #}
{% extends 'layouts/admin.html.twig' %}

{% block title %}Create New Order - SMSol Studio{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('staff_orders') }}">Orders</a></li>
<li class="breadcrumb-item active">New Order</li>
{% endblock %}

{% block page_title %}Create New Order{% endblock %}
{% block page_description %}Add a new customer order{% endblock %}

{% block admin_content %}
<div class="row">
    <div class="col-lg-8">
        <div class="card admin-chart">
            <div class="card-header bg-white border-0">
                <h5 class="mb-0">Order Information</h5>
            </div>
            <div class="card-body">
                {{ form_start(form, {'attr': {'class': 'row g-3'}}) }}
                
                <div class="col-md-6">
                    {{ form_label(form.customer, 'Customer *', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.customer, {'attr': {'class': 'form-select', 'required': 'required'}}) }}
                    {{ form_errors(form.customer) }}
                    <div class="form-text">Select an existing customer or <a href="{{ path('admin_users') }}" target="_blank">add new customer</a> first</div>
                </div>
                
                <div class="col-md-6">
                    {{ form_label(form.deliveryType, 'Delivery Type *', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.deliveryType, {'attr': {'class': 'form-select', 'required': 'required'}}) }}
                    {{ form_errors(form.deliveryType) }}
                </div>
                
                <div class="col-md-6">
                    {{ form_label(form.paymentMethod, 'Payment Method *', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.paymentMethod, {'attr': {'class': 'form-select', 'required': 'required'}}) }}
                    {{ form_errors(form.paymentMethod) }}
                </div>
                
                <div class="col-md-6">
                    {{ form_label(form.isUrgent, 'Urgent Order', {'label_attr': {'class': 'form-label'}}) }}
                    <div class="form-check form-switch mt-2">
                        {{ form_widget(form.isUrgent, {'attr': {'class': 'form-check-input', 'role': 'switch'}}) }}
                        <label class="form-check-label" for="{{ form.isUrgent.vars.id }}">
                            Mark as urgent priority
                        </label>
                    </div>
                    {{ form_errors(form.isUrgent) }}
                </div>
                
                <div class="col-12" id="deliveryAddressSection" style="display: none;">
                    {{ form_label(form.deliveryAddress, 'Delivery Address', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.deliveryAddress, {'attr': {'class': 'form-control', 'rows': 3, 'placeholder': 'Enter complete delivery address'}}) }}
                    {{ form_errors(form.deliveryAddress) }}
                </div>
                
                <div class="col-md-6" id="deliveryFeeSection" style="display: none;">
                    {{ form_label(form.deliveryFee, 'Delivery Fee (₱)', {'label_attr': {'class': 'form-label'}}) }}
                    <div class="input-group">
                        <span class="input-group-text">₱</span>
                        {{ form_widget(form.deliveryFee, {'attr': {'class': 'form-control', 'min': '0', 'step': '0.01', 'placeholder': '0.00'}}) }}
                    </div>
                    {{ form_errors(form.deliveryFee) }}
                    <div class="form-text">Delivery charge for customer</div>
                </div>
                
                <div class="col-12">
                    {{ form_label(form.notes, 'Order Notes', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.notes, {'attr': {'class': 'form-control', 'rows': 3, 'placeholder': 'Special instructions or notes...'}}) }}
                    {{ form_errors(form.notes) }}
                    <div class="form-text">Internal notes for staff reference</div>
                </div>
                
                <div class="col-12 mt-4">
                    <div class="d-flex justify-content-end gap-2">
                        <a href="{{ path('staff_orders') }}" class="btn btn-secondary">
                            <i class="bi bi-x-circle me-2"></i>Cancel
                        </a>
                        {{ form_widget(form.save, {'attr': {'class': 'btn btn-primary'}, 'label': 'Continue to Add Products'}) }}
                    </div>
                </div>
                
                {{ form_end(form) }}
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="card admin-chart">
            <div class="card-header bg-white border-0">
                <h5 class="mb-0">Quick Actions</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="{{ path('staff_product_new') }}" class="btn btn-outline-primary text-start">
                        <i class="bi bi-plus-circle me-2"></i>Add New Product
                    </a>
                    <a href="{{ path('admin_users') }}" class="btn btn-outline-success text-start">
                        <i class="bi bi-person-plus me-2"></i>Add New Customer
                    </a>
                    <a href="{{ path('staff_orders') }}" class="btn btn-outline-secondary text-start">
                        <i class="bi bi-arrow-left me-2"></i>Back to Orders
                    </a>
                </div>
                
                <hr class="my-4">
                
                <h6 class="mb-3">Order Tips</h6>
                <ul class="list-unstyled text-muted small">
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Verify customer information</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Check product availability</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Confirm delivery/pickup details</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Provide clear instructions if needed</li>
                    <li class="mb-2"><i class="bi bi-exclamation-triangle text-warning me-2"></i>Urgent orders require priority handling</li>
                </ul>
                
                <hr class="my-4">
                
                <h6 class="mb-3">Required Fields</h6>
                <ul class="list-unstyled small">
                    <li class="mb-1"><span class="text-danger">*</span> Customer</li>
                    <li class="mb-1"><span class="text-danger">*</span> Delivery Type</li>
                    <li><span class="text-danger">*</span> Payment Method</li>
                </ul>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Show/hide delivery address and fee based on delivery type
    const deliveryTypeSelect = document.getElementById('{{ form.deliveryType.vars.id }}');
    const addressSection = document.getElementById('deliveryAddressSection');
    const feeSection = document.getElementById('deliveryFeeSection');
    
    function toggleDeliveryFields() {
        if (deliveryTypeSelect.value === 'delivery') {
            if (addressSection) addressSection.style.display = 'block';
            if (feeSection) feeSection.style.display = 'block';
        } else {
            if (addressSection) addressSection.style.display = 'none';
            if (feeSection) feeSection.style.display = 'none';
        }
    }
    
    // Initial toggle
    toggleDeliveryFields();
    
    // Add event listener
    if (deliveryTypeSelect) {
        deliveryTypeSelect.addEventListener('change', toggleDeliveryFields);
    }
    
    // Form validation
    document.querySelector('form').addEventListener('submit', function(event) {
        const customerField = document.getElementById('{{ form.customer.vars.id }}');
        const deliveryTypeField = document.getElementById('{{ form.deliveryType.vars.id }}');
        const paymentMethodField = document.getElementById('{{ form.paymentMethod.vars.id }}');
        
        let isValid = true;
        let errorMessage = '';
        
        if (!customerField.value) {
            isValid = false;
            errorMessage += '• Customer is required\n';
        }
        
        if (!deliveryTypeField.value) {
            isValid = false;
            errorMessage += '• Delivery Type is required\n';
        }
        
        if (!paymentMethodField.value) {
            isValid = false;
            errorMessage += '• Payment Method is required\n';
        }
        
        if (deliveryTypeField.value === 'delivery') {
            const deliveryAddressField = document.getElementById('{{ form.deliveryAddress.vars.id }}');
            if (deliveryAddressField && !deliveryAddressField.value.trim()) {
                isValid = false;
                errorMessage += '• Delivery Address is required for delivery orders\n';
            }
        }
        
        if (!isValid) {
            event.preventDefault();
            alert('Please fill in all required fields:\n\n' + errorMessage);
        }
    });
    
    // Auto-focus customer field
    if (document.getElementById('{{ form.customer.vars.id }}')) {
        document.getElementById('{{ form.customer.vars.id }}').focus();
    }
});
</script>

<style>
.form-label.required:after {
    content: " *";
    color: #dc3545;
}

.form-check-input:checked {
    background-color: #0d6efd;
    border-color: #0d6efd;
}

.input-group-text {
    background-color: #f8f9fa;
    border-color: #dee2e6;
}

#deliveryAddressSection, #deliveryFeeSection {
    transition: all 0.3s ease;
}

.btn-group .btn {
    border-radius: 0.375rem;
}
</style>
{% endblock %}