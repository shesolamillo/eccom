{# Quick Cart Preview Dropdown #}
<div class="position-relative">
    <!-- Cart Icon with Badge -->
    <button class="btn btn-outline-secondary position-relative" id="cartPreviewBtn" style="border-radius: 50%; width: 50px; height: 50px; padding: 0; display: flex; align-items: center; justify-content: center;">
        <i class="bi bi-bag" style="font-size: 1.5rem;"></i>
        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display: none;" id="cartBadge">
            0
        </span>
    </button>

    <!-- Cart Preview Dropdown -->
    <div class="position-absolute end-0 mt-2 bg-white rounded-3 shadow-lg border-0" style="width: 380px; max-height: 500px; display: none; z-index: 1050; top: 100%;" id="cartPreview">
        <div class="p-4 border-bottom">
            <h6 class="mb-0 fw-bold">
                <i class="bi bi-bag me-2"></i>Shopping Cart
                <span class="badge bg-secondary float-end" id="previewItemCount">0</span>
            </h6>
        </div>

        <!-- Cart Items List -->
        <div class="overflow-y-auto" style="max-height: 300px;" id="cartItemsList">
            <div class="text-center py-5 text-muted">
                <i class="bi bi-bag-slash display-3 d-block mb-2"></i>
                Your cart is empty
            </div>
        </div>

        <!-- Cart Summary -->
        <div class="p-4 border-top" id="cartSummary" style="display: none;">
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Subtotal:</span>
                <strong id="previewSubtotal">₱0.00</strong>
            </div>
            <div class="d-flex justify-content-between mb-3 pb-3 border-bottom">
                <span class="text-muted">Shipping:</span>
                <strong id="previewShipping" class="text-success">FREE</strong>
            </div>
            <div class="d-flex justify-content-between mb-4">
                <span class="fw-bold">Total:</span>
                <strong class="text-primary fs-5" id="previewTotal">₱0.00</strong>
            </div>
            <div class="d-grid gap-2">
                <a href="{{ path('cart_view') }}" class="btn btn-primary">
                    <i class="bi bi-arrow-right-circle me-2"></i>View Cart
                </a>
                <button type="button" class="btn btn-outline-danger" id="clearCartPreviewBtn">
                    <i class="bi bi-trash me-2"></i>Clear
                </button>
            </div>
        </div>
    </div>
</div>

<style>
#cartPreview {
    animation: slideInUp 0.3s ease-out;
}

@keyframes slideInUp {
    from {
        opacity: 0;
        transform: translateY(-10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.cart-item-preview {
    padding: 1rem;
    border-bottom: 1px solid #e9ecef;
    display: flex;
    gap: 1rem;
    align-items: center;
    transition: background-color 0.3s ease;
}

.cart-item-preview:hover {
    background-color: #f8f9fa;
}

.cart-item-image {
    width: 60px;
    height: 60px;
    border-radius: 0.5rem;
    object-fit: cover;
    background: #f8f9fa;
}

.cart-item-info {
    flex: 1;
}

.cart-item-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: #333;
    margin-bottom: 0.25rem;
}

.cart-item-details {
    font-size: 0.75rem;
    color: #6c757d;
}

.cart-item-price {
    font-weight: 700;
    color: #667eea;
    font-size: 0.95rem;
}

.cart-item-remove {
    cursor: pointer;
    color: #dc3545;
    transition: transform 0.2s ease;
}

.cart-item-remove:hover {
    transform: scale(1.2);
}
</style>
