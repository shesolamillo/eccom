{# templates/product/staff/new.html.twig #}
{% extends 'layouts/admin.html.twig' %}

{% block title %}Add New Product - SMSol Studio{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('staff_products') }}">Products</a></li>
<li class="breadcrumb-item active">New Product</li>
{% endblock %}

{% block page_title %}Add New Product{% endblock %}
{% block page_description %}Create a new product for your store{% endblock %}

{% block admin_content %}
<div class="row">
    <div class="col-lg-8">
        <div class="card admin-chart">
            <div class="card-header bg-white border-0">
                <h5 class="mb-0">Product Information</h5>
            </div>
            <div class="card-body">
                {{ form_start(form, {'attr': {'class': 'row g-3', 'enctype': 'multipart/form-data'}}) }}
                    
                    <div class="col-md-6">
                        {{ form_label(form.name, 'Product Name *', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Enter product name', 'required': 'required'}}) }}
                        {{ form_errors(form.name) }}
                        <div class="form-text">Enter a descriptive product name</div>
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.sku, 'SKU (Stock Keeping Unit)', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.sku, {'attr': {'class': 'form-control', 'placeholder': 'Leave blank to auto-generate'}}) }}
                        {{ form_errors(form.sku) }}
                        <div class="form-text">Unique identifier for inventory tracking</div>
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.price, 'Price (₱) *', {'label_attr': {'class': 'form-label'}}) }}
                        <div class="input-group">
                            <span class="input-group-text">₱</span>
                            {{ form_widget(form.price, {'attr': {'class': 'form-control', 'min': '0', 'step': '0.01', 'required': 'required'}}) }}
                        </div>
                        {{ form_errors(form.price) }}
                        <div class="form-text">Selling price per unit</div>
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.costPrice, 'Cost Price (₱)', {'label_attr': {'class': 'form-label'}}) }}
                        <div class="input-group">
                            <span class="input-group-text">₱</span>
                            {{ form_widget(form.costPrice, {'attr': {'class': 'form-control', 'min': '0', 'step': '0.01'}}) }}
                        </div>
                        {{ form_errors(form.costPrice) }}
                        <div class="form-text">Purchase or manufacturing cost</div>
                    </div>
                    
                    <div class="col-12">
                        {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 3, 'placeholder': 'Product description, features, specifications...'}}) }}
                        {{ form_errors(form.description) }}
                        <div class="form-text">Detailed product information</div>
                    </div>
                    
                    <!-- Product Photo -->
                    <div class="col-12">
                        {{ form_label(form.photo, 'Product Photo', {'label_attr': {'class': 'form-label'}}) }}
                        <div class="input-group">
                            {{ form_widget(form.photo, {'attr': {
                                'class': 'form-control',
                                'accept': 'image/jpeg,image/png,image/webp,image/gif'
                            }}) }}
                            <label class="input-group-text" for="{{ form.photo.vars.id }}">
                                <i class="bi bi-upload"></i>
                            </label>
                        </div>
                        {{ form_errors(form.photo) }}
                        <div class="form-text">
                            <i class="bi bi-info-circle"></i> Supported formats: JPG, PNG, WebP, GIF (Max 5MB)
                        </div>
                        
                        <!-- Image Preview -->
                        <div class="mt-2" id="imagePreviewContainer" style="display: none;">
                            <h6 class="mt-3 mb-2">Image Preview:</h6>
                            <div class="border rounded p-3 text-center">
                                <img id="imagePreview" src="" alt="Preview" class="img-fluid rounded" style="max-height: 200px;">
                                <div class="mt-2">
                                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeImage()">
                                        <i class="bi bi-trash me-1"></i>Remove Image
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Product Type -->
                    {% if form.productType is defined %}
                    <div class="col-md-6">
                        {{ form_label(form.productType, 'Product Type *', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.productType, {'attr': {'class': 'form-select', 'required': 'required'}}) }}
                        {{ form_errors(form.productType) }}
                        <div class="form-text">Select product category type</div>
                    </div>
                    {% endif %}
                    
                    <!-- Category -->
                    {% if form.clothesCategory is defined %}
                    <div class="col-md-6">
                        {{ form_label(form.clothesCategory, 'Category *', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.clothesCategory, {'attr': {'class': 'form-select', 'required': 'required'}}) }}
                        {{ form_errors(form.clothesCategory) }}
                        <div class="form-text">Main product category</div>
                    </div>
                    {% endif %}
                    
                    <!-- Subcategory (if available) -->
                    {% if form.subcategory is defined %}
                    <div class="col-md-6">
                        {{ form_label(form.subcategory, 'Subcategory', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.subcategory, {'attr': {'class': 'form-select'}}) }}
                        {{ form_errors(form.subcategory) }}
                    </div>
                    {% endif %}
                    
                    <!-- Tags (if available) -->
                    {% if form.tags is defined %}
                    <div class="col-12">
                        {{ form_label(form.tags, 'Tags', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.tags, {'attr': {'class': 'form-control', 'placeholder': 'Enter tags separated by commas'}}) }}
                        {{ form_errors(form.tags) }}
                        <div class="form-text">Keywords for searching and filtering</div>
                    </div>
                    {% endif %}
                    
                    <!-- Size (if available) -->
                    {% if form.size is defined %}
                    <div class="col-md-4">
                        {{ form_label(form.size, 'Size', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.size, {'attr': {'class': 'form-control', 'placeholder': 'e.g., S, M, L, XL'}}) }}
                        {{ form_errors(form.size) }}
                    </div>
                    {% endif %}
                    
                    <!-- Color (if available) -->
                    {% if form.color is defined %}
                    <div class="col-md-4">
                        {{ form_label(form.color, 'Color', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.color, {'attr': {'class': 'form-control', 'placeholder': 'e.g., Red, Blue, Black'}}) }}
                        {{ form_errors(form.color) }}
                    </div>
                    {% endif %}
                    
                    <!-- Material (if available) -->
                    {% if form.material is defined %}
                    <div class="col-md-4">
                        {{ form_label(form.material, 'Material', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.material, {'attr': {'class': 'form-control', 'placeholder': 'e.g., Cotton, Polyester'}}) }}
                        {{ form_errors(form.material) }}
                    </div>
                    {% endif %}
                    
                    <!-- Weight (if available) -->
                    {% if form.weight is defined %}
                    <div class="col-md-6">
                        {{ form_label(form.weight, 'Weight (kg)', {'label_attr': {'class': 'form-label'}}) }}
                        <div class="input-group">
                            {{ form_widget(form.weight, {'attr': {'class': 'form-control', 'min': '0', 'step': '0.001'}}) }}
                            <span class="input-group-text">kg</span>
                        </div>
                        {{ form_errors(form.weight) }}
                        <div class="form-text">Product weight for shipping</div>
                    </div>
                    {% endif %}
                    
                    <!-- Dimensions (if available) -->
                    {% if form.dimensions is defined %}
                    <div class="col-md-6">
                        {{ form_label(form.dimensions, 'Dimensions (cm)', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.dimensions, {'attr': {'class': 'form-control', 'placeholder': 'L x W x H'}}) }}
                        {{ form_errors(form.dimensions) }}
                        <div class="form-text">e.g., 30 x 20 x 10</div>
                    </div>
                    {% endif %}
                    
                    <!-- Status -->
                    <div class="col-md-6">
                        <div class="form-check form-switch mt-4 pt-2">
                            {{ form_widget(form.isAvailable, {'attr': {
                                'class': 'form-check-input',
                                'role': 'switch',
                                'checked': 'checked'
                            }}) }}
                            {{ form_label(form.isAvailable, 'Available for Sale', {'label_attr': {'class': 'form-check-label'}}) }}
                        </div>
                        <div class="form-text">Product visibility in store</div>
                    </div>
                    
                    <!-- Featured Product (if available) -->
                    {% if form.isFeatured is defined %}
                    <div class="col-md-6">
                        <div class="form-check form-switch mt-4 pt-2">
                            {{ form_widget(form.isAvailable, {'attr': {
                                'class': 'form-check-input',
                                'role': 'switch'
                            }}) }}
                            {{ form_label(form.isAvailable, 'Featured Product', {'label_attr': {'class': 'form-check-label'}}) }}
                        </div>
                        <div class="form-text">Show on homepage/featured section</div>
                    </div>
                    {% endif %}
                    
                    <!-- SEO Fields (if available) -->
                    {% if form.metaTitle is defined %}
                    <div class="col-12">
                        <h6 class="mt-4 mb-3 border-bottom pb-2">SEO Settings</h6>
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.metaTitle, 'Meta Title', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.metaTitle, {'attr': {'class': 'form-control', 'placeholder': 'SEO title for search engines'}}) }}
                        {{ form_errors(form.metaTitle) }}
                        <div class="form-text">Title for search engine results</div>
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.metaDescription, 'Meta Description', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.metaDescription, {'attr': {'class': 'form-control', 'rows': 2, 'placeholder': 'Brief description for search engines'}}) }}
                        {{ form_errors(form.metaDescription) }}
                        <div class="form-text">Description for search engine results</div>
                    </div>
                    {% endif %}
                    
                    <!-- Save Buttons -->
                    <div class="col-12 mt-4 pt-3 border-top">
                        <div class="d-flex justify-content-between gap-2">
                            <a href="{{ path('staff_products') }}" class="btn btn-secondary">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </a>
                            <div class="btn-group">
                                <button type="submit" name="save" class="btn btn-primary">
                                    <i class="bi bi-plus-circle me-2"></i>Create Product
                                </button>
                                <button type="submit" name="save_and_add_another" class="btn btn-outline-primary">
                                    <i class="bi bi-plus-circle-dotted me-2"></i>Create & Add Another
                                </button>
                            </div>
                        </div>
                    </div>
                    
                {{ form_end(form) }}
            </div>
        </div>
    </div>
    
    <!-- Right Sidebar -->
    <div class="col-lg-4">
        <!-- Quick Tips -->
        <div class="card admin-chart mb-4">
            <div class="card-header bg-white border-0">
                <h5 class="mb-0">Quick Tips</h5>
            </div>
            <div class="card-body">
                <ul class="list-unstyled text-muted small">
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Use clear, descriptive product names</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Set accurate pricing and cost</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Add detailed descriptions</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Categorize products for better organization</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Upload high-quality product photos</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Add tags for better searchability</li>
                    <li class="mb-2"><i class="bi bi-exclamation-triangle text-warning me-2"></i>Don't forget to add stock after creating</li>
                </ul>
                
                <hr class="my-3">
                
                <h6 class="mb-2">Required Fields</h6>
                <ul class="list-unstyled small">
                    <li class="mb-1"><span class="text-danger">*</span> Product Name</li>
                    <li class="mb-1"><span class="text-danger">*</span> Price</li>
                    <li class="mb-1"><span class="text-danger">*</span> Product Type</li>
                    <li><span class="text-danger">*</span> Category</li>
                </ul>
            </div>
        </div>
        
        <!-- Quick Actions -->
        <div class="card admin-chart">
            <div class="card-header bg-white border-0">
                <h5 class="mb-0">Quick Actions</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="{{ path('staff_stock_add') }}" class="btn btn-outline-primary text-start">
                        <i class="bi bi-box me-2"></i>Add Stock
                    </a>
                    <a href="{{ path('staff_products') }}" class="btn btn-outline-secondary text-start">
                        <i class="bi bi-arrow-left me-2"></i>Back to Products
                    </a>
                    <a href="{{ path('staff_product_new') }}" class="btn btn-outline-success text-start">
                        <i class="bi bi-plus-circle me-2"></i>Add Another Product
                    </a>
                </div>
                
                <hr class="my-3">
                
                <h6 class="mb-2">Product Categories</h6>
                {% if categories|length > 0 %}
                    <div class="list-group list-group-flush">
                        {% for category in categories|slice(0, 5) %}
                            <div class="list-group-item px-0 py-2 d-flex justify-content-between align-items-center">
                                <span>{{ category.name }}</span>
                                <span class="badge bg-light text-dark">{{ category.products|length }}</span>
                            </div>
                        {% endfor %}
                        {% if categories|length > 5 %}
                            <div class="list-group-item px-0 py-2 text-center">
                                <small class="text-muted">+ {{ categories|length - 5 }} more categories</small>
                            </div>
                        {% endif %}
                    </div>
                {% else %}
                    <p class="text-muted small">No categories available</p>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// Image preview functionality
document.getElementById('{{ form.photo.vars.id }}').addEventListener('change', function(event) {
    const file = event.target.files[0];
    const previewContainer = document.getElementById('imagePreviewContainer');
    const previewImage = document.getElementById('imagePreview');
    
    if (file) {
        const reader = new FileReader();
        
        reader.onload = function(e) {
            previewImage.src = e.target.result;
            previewContainer.style.display = 'block';
        };
        
        reader.readAsDataURL(file);
    } else {
        previewContainer.style.display = 'none';
        previewImage.src = '';
    }
});

function removeImage() {
    const fileInput = document.getElementById('{{ form.photo.vars.id }}');
    const previewContainer = document.getElementById('imagePreviewContainer');
    const previewImage = document.getElementById('imagePreview');
    
    fileInput.value = '';
    previewImage.src = '';
    previewContainer.style.display = 'none';
}

// Auto-generate SKU based on product name
document.getElementById('{{ form.name.vars.id }}').addEventListener('input', function() {
    const skuField = document.getElementById('{{ form.sku.vars.id }}');
    if (!skuField.value) {
        // Generate a simple SKU from the product name
        const productName = this.value;
        if (productName.length > 0) {
            // Remove special characters, take first 8 characters, convert to uppercase
            let generatedSku = productName
                .replace(/[^a-zA-Z0-9]/g, '')
                .substring(0, 8)
                .toUpperCase();
            
            // Add timestamp for uniqueness
            const timestamp = Date.now().toString().slice(-4);
            skuField.value = generatedSku + '-' + timestamp;
        }
    }
});

// Form validation
document.querySelector('form').addEventListener('submit', function(event) {
    const requiredFields = [
        '{{ form.name.vars.id }}',
        '{{ form.price.vars.id }}',
        '{{ form.productType.vars.id }}',
        '{{ form.clothesCategory.vars.id }}'
    ];
    
    let isValid = true;
    let errorMessage = '';
    
    requiredFields.forEach(fieldId => {
        const field = document.getElementById(fieldId);
        if (field && !field.value.trim()) {
            isValid = false;
            const label = field.closest('.col-md-6, .col-12')?.querySelector('.form-label')?.textContent || 'Field';
            errorMessage += `• ${label.replace(' *', '')} is required\n`;
        }
    });
    
    if (!isValid) {
        event.preventDefault();
        alert('Please fill in all required fields:\n\n' + errorMessage);
    }
});

// Price validation
document.getElementById('{{ form.price.vars.id }}').addEventListener('blur', function() {
    const value = parseFloat(this.value);
    if (value < 0) {
        alert('Price cannot be negative');
        this.value = 0;
    }
});

// Cost price validation
const costPriceField = document.getElementById('{{ form.costPrice.vars.id }}');
if (costPriceField) {
    costPriceField.addEventListener('blur', function() {
        const value = parseFloat(this.value);
        if (value < 0) {
            alert('Cost price cannot be negative');
            this.value = 0;
        }
    });
}
</script>

<style>
.form-label.required:after {
    content: " *";
    color: #dc3545;
}

.input-group-text {
    background-color: #f8f9fa;
    border-color: #dee2e6;
}

.form-switch .form-check-input:checked {
    background-color: #0d6efd;
    border-color: #0d6efd;
}

#imagePreviewContainer img {
    max-width: 100%;
    height: auto;
    object-fit: contain;
}

.btn-group .btn {
    border-radius: 0.375rem !important;
}

.btn-group .btn:first-child {
    border-top-right-radius: 0 !important;
    border-bottom-right-radius: 0 !important;
}

.btn-group .btn:last-child {
    border-top-left-radius: 0 !important;
    border-bottom-left-radius: 0 !important;
}

.list-group-item {
    border: none;
    background: transparent;
}

.list-group-item:not(:last-child) {
    border-bottom: 1px solid #dee2e6;
}
</style>
{% endblock %}  