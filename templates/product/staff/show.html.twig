{# templates/product/staff/show.html.twig #}
{% extends 'layouts/admin.html.twig' %}

{% block title %}{{ product.name }} - Product Details - SMSol Studio{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('staff_products') }}">Products</a></li>
<li class="breadcrumb-item active">{{ product.name }}</li>
{% endblock %}

{% block page_title %}{{ product.name }}{% endblock %}
{% block page_description %}Product details and information{% endblock %}

{% block page_actions %}
<div class="btn-group">
    <a href="{{ path('staff_product_edit', {'id': product.id}) }}" class="btn btn-primary">
        <i class="bi bi-pencil me-2"></i>Edit
    </a>
    <a href="{{ path('staff_products') }}" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-2"></i>Back to Products
    </a>
</div>
{% endblock %}

{% block admin_content %}
<div class="row">
    <div class="col-lg-8">
        <!-- Product Information Card -->
        <div class="card admin-chart mb-4">
            <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Product Information</h5>
                <div class="d-flex gap-2">
                    <span class="badge {{ product.isActive ? 'bg-success' : 'bg-danger' }}">
                        {{ product.isActive ? 'Available' : 'Unavailable' }}
                    </span>
                    {% if product.isFeatured|default(false) %}
                        <span class="badge bg-warning">Featured</span>
                    {% endif %}
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <!-- Product Image -->
                    <div class="col-md-4 mb-3 mb-md-0">
                        {% if product.photo %}
                            <div class="product-image-container">
                                <img src="{{ asset('uploads/products/' ~ product.photo) }}" 
                                     alt="{{ product.name }}" 
                                     class="img-fluid rounded shadow-sm"
                                     id="mainProductImage">
                                <div class="mt-2 text-center">
                                    <button type="button" class="btn btn-sm btn-outline-secondary" 
                                            onclick="openImageModal('{{ asset('uploads/products/' ~ product.photo) }}')">
                                        <i class="bi bi-zoom-in me-1"></i>View Full Size
                                    </button>
                                </div>
                            </div>
                        {% else %}
                            <div class="bg-light rounded d-flex align-items-center justify-content-center" 
                                 style="height: 250px;">
                                <div class="text-center text-muted">
                                    <i class="bi bi-image" style="font-size: 3rem;"></i>
                                    <p class="mt-2">No image available</p>
                                </div>
                            </div>
                        {% endif %}
                    </div>
                    
                    <!-- Product Details -->
                    <div class="col-md-8">
                        <table class="table table-sm table-borderless">
                            <tr>
                                <th width="30%" class="text-muted">Name:</th>
                                <td><strong>{{ product.name }}</strong></td>
                            </tr>
                            <tr>
                                <th class="text-muted">SKU:</th>
                                <td>
                                    <span class="badge bg-info">{{ product.sku|default('N/A') }}</span>
                                    {% if product.sku %}
                                        <button type="button" class="btn btn-sm btn-outline-secondary ms-2" 
                                                onclick="copyToClipboard('{{ product.sku }}')">
                                            <i class="bi bi-clipboard"></i>
                                        </button>
                                    {% endif %}
                                </td>
                            </tr>
                            <tr>
                                <th class="text-muted">Price:</th>
                                <td>
                                    <span class="fw-bold fs-5 text-primary">₱{{ product.price|number_format(2) }}</span>
                                    {% if product.costPrice %}
                                        <small class="text-muted ms-2">
                                            (Cost: ₱{{ product.costPrice|number_format(2) }})
                                        </small>
                                    {% endif %}
                                </td>
                            </tr>
                            <tr>
                                <th class="text-muted">Profit Margin:</th>
                                <td>
                                    {% if product.costPrice %}
                                        {% set profit = product.price - product.costPrice %}
                                        {% set margin = (profit / product.costPrice) * 100 %}
                                        <span class="fw-bold {{ margin >= 0 ? 'text-success' : 'text-danger' }}">
                                            ₱{{ profit|number_format(2) }} ({{ margin|number_format(1) }}%)
                                        </span>
                                    {% else %}
                                        <span class="text-muted">N/A</span>
                                    {% endif %}
                                </td>
                            </tr>
                            <tr>
                                <th class="text-muted">Category:</th>
                                <td>{{ product.category.name|default('Uncategorized') }}</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Type:</th>
                                <td>{{ product.type.name|default('N/A') }}</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Created By:</th>
                                <td>{{ product.createdBy.fullName|default('System') }}</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Created:</th>
                                <td>{{ product.createdAt|date('F j, Y h:i A') }}</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Last Updated:</th>
                                <td>{{ product.updatedAt|date('F j, Y h:i A') }}</td>
                            </tr>
                            {% if product.tags %}
                            <tr>
                                <th class="text-muted">Tags:</th>
                                <td>
                                    {% for tag in product.tags|split(',') %}
                                        <span class="badge bg-light text-dark me-1">{{ tag|trim }}</span>
                                    {% endfor %}
                                </td>
                            </tr>
                            {% endif %}
                        </table>
                    </div>
                </div>
                
                <!-- Description -->
                {% if product.description %}
                <div class="row mt-4">
                    <div class="col-12">
                        <h6 class="border-bottom pb-2 mb-3">Description</h6>
                        <div class="card bg-light">
                            <div class="card-body">
                                {{ product.description|nl2br }}
                            </div>
                        </div>
                    </div>
                </div>
                {% endif %}
                
                <!-- Additional Details -->
                <div class="row mt-4">
                    {% if product.size or product.color or product.material %}
                    <div class="col-md-6">
                        <h6 class="border-bottom pb-2 mb-3">Specifications</h6>
                        <table class="table table-sm">
                            {% if product.size %}
                            <tr>
                                <th width="40%">Size:</th>
                                <td>{{ product.size }}</td>
                            </tr>
                            {% endif %}
                            {% if product.color %}
                            <tr>
                                <th>Color:</th>
                                <td>{{ product.color }}</td>
                            </tr>
                            {% endif %}
                            {% if product.material %}
                            <tr>
                                <th>Material:</th>
                                <td>{{ product.material }}</td>
                            </tr>
                            {% endif %}
                            {% if product.weight %}
                            <tr>
                                <th>Weight:</th>
                                <td>{{ product.weight }} kg</td>
                            </tr>
                            {% endif %}
                            {% if product.dimensions %}
                            <tr>
                                <th>Dimensions:</th>
                                <td>{{ product.dimensions }} cm</td>
                            </tr>
                            {% endif %}
                        </table>
                    </div>
                    {% endif %}
                    
                    <!-- SEO Information -->
                    {% if product.metaTitle or product.metaDescription %}
                    <div class="col-md-6">
                        <h6 class="border-bottom pb-2 mb-3">SEO Information</h6>
                        <div class="bg-light p-3 rounded">
                            {% if product.metaTitle %}
                            <p class="mb-1"><strong>Meta Title:</strong></p>
                            <p class="text-muted small">{{ product.metaTitle }}</p>
                            {% endif %}
                            {% if product.metaDescription %}
                            <p class="mb-1 mt-3"><strong>Meta Description:</strong></p>
                            <p class="text-muted small">{{ product.metaDescription }}</p>
                            {% endif %}
                        </div>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
        
        <!-- Stock Information Card -->
        <div class="card admin-chart mb-4">
            <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Stock Information</h5>
                <div class="d-flex gap-2">
                    {% if product.stock %}
                        <a href="{{ path('staff_stock_update', {'id': product.stock.id}) }}" 
                           class="btn btn-sm btn-primary">
                            <i class="bi bi-box-arrow-in-down me-1"></i>Update Stock
                        </a>
                    {% else %}
                        <a href="{{ path('staff_stock_add') }}?product={{ product.id }}" 
                           class="btn btn-sm btn-success">
                            <i class="bi bi-plus-circle me-1"></i>Add Stock
                        </a>
                    {% endif %}
                </div>
            </div>
            <div class="card-body">
                {% if product.stock %}
                    <div class="row text-center mb-4">
                        <div class="col-md-3 col-6 mb-3">
                            <div class="card border-0 bg-light h-100">
                                <div class="card-body py-3">
                                    <h3 class="fw-bold mb-1 {{ product.stock.quantity == 0 ? 'text-danger' : (product.stock.quantity <= product.stock.reorderPoint|default(5) ? 'text-warning' : 'text-success') }}">
                                        {{ product.stock.quantity }}
                                    </h3>
                                    <small class="text-muted">Current Stock</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-6 mb-3">
                            <div class="card border-0 bg-light h-100">
                                <div class="card-body py-3">
                                    <h3 class="fw-bold mb-1">{{ product.stock.minimumQuantity|default(10) }}</h3>
                                    <small class="text-muted">Minimum Stock</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-6 mb-3">
                            <div class="card border-0 bg-light h-100">
                                <div class="card-body py-3">
                                    <h3 class="fw-bold mb-1">{{ product.stock.reorderPoint|default(5) }}</h3>
                                    <small class="text-muted">Reorder Point</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-6 mb-3">
                            <div class="card border-0 bg-light h-100">
                                <div class="card-body py-3">
                                    <h3 class="fw-bold mb-1">{{ product.totalSold|default(0) }}</h3>
                                    <small class="text-muted">Total Sold</small>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Stock Status -->
                    <div class="row">
                        <div class="col-12">
                            <h6 class="mb-3">Stock Status</h6>
                            {% if product.stock.quantity == 0 %}
                                <div class="alert alert-danger d-flex align-items-center">
                                    <i class="bi bi-exclamation-triangle fs-4 me-3"></i>
                                    <div>
                                        <h5 class="alert-heading mb-1">Out of Stock!</h5>
                                        <p class="mb-0">This product has no available stock. Consider restocking immediately.</p>
                                    </div>
                                </div>
                            {% elseif product.stock.quantity <= product.stock.reorderPoint|default(5) %}
                                <div class="alert alert-warning d-flex align-items-center">
                                    <i class="bi bi-exclamation-circle fs-4 me-3"></i>
                                    <div>
                                        <h5 class="alert-heading mb-1">Low Stock Warning!</h5>
                                        <p class="mb-0">Stock level ({{ product.stock.quantity }}) is at or below reorder point ({{ product.stock.reorderPoint|default(5) }}). Consider restocking.</p>
                                    </div>
                                </div>
                            {% else %}
                                <div class="alert alert-success d-flex align-items-center">
                                    <i class="bi bi-check-circle fs-4 me-3"></i>
                                    <div>
                                        <h5 class="alert-heading mb-1">Stock Level Good</h5>
                                        <p class="mb-0">Stock level is healthy. Current stock: {{ product.stock.quantity }} units.</p>
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                    
                    <!-- Stock History (if available) -->
                    {% if product.stock.adjustments|length > 0 %}
                    <div class="row mt-4">
                        <div class="col-12">
                            <h6 class="border-bottom pb-2 mb-3">Recent Stock Adjustments</h6>
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Date</th>
                                            <th>Type</th>
                                            <th>Previous</th>
                                            <th>New</th>
                                            <th>Change</th>
                                            <th>Reason</th>
                                            <th>By</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for adjustment in product.stock.adjustments|slice(0, 5) %}
                                        <tr>
                                            <td>{{ adjustment.adjustedAt|date('M d, Y') }}</td>
                                            <td>
                                                <span class="badge bg-{{ adjustment.adjustmentType == 'add' ? 'success' : (adjustment.adjustmentType == 'remove' ? 'danger' : 'warning') }}">
                                                    {{ adjustment.adjustmentType|title }}
                                                </span>
                                            </td>
                                            <td>{{ adjustment.previousQuantity }}</td>
                                            <td>{{ adjustment.newQuantity }}</td>
                                            <td class="{{ adjustment.newQuantity > adjustment.previousQuantity ? 'text-success' : 'text-danger' }}">
                                                {{ adjustment.newQuantity > adjustment.previousQuantity ? '+' : '' }}{{ adjustment.newQuantity - adjustment.previousQuantity }}
                                            </td>
                                            <td>{{ adjustment.reason|default('N/A') }}</td>
                                            <td>{{ adjustment.adjustedBy.fullName|default('System') }}</td>
                                        </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    {% endif %}
                {% else %}
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-box-x fs-1"></i>
                        <p class="mt-3 mb-4">No stock information available for this product</p>
                        <a href="{{ path('staff_stock_add') }}?product={{ product.id }}" 
                           class="btn btn-primary">
                            <i class="bi bi-plus-circle me-2"></i>Add Stock Information
                        </a>
                    </div>
                {% endif %}
            </div>
        </div>
        
        <!-- Recent Orders Card -->
        {% if product.orderItems|length > 0 %}
        <div class="card admin-chart">
            <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Recent Orders</h5>
                <span class="badge bg-info">{{ product.orderItems|length }} total orders</span>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm table-hover">
                        <thead class="bg-light">
                            <tr>
                                <th>Order #</th>
                                <th>Date</th>
                                <th>Customer</th>
                                <th>Qty</th>
                                <th>Total</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for orderItem in product.orderItems|slice(0, 10)|sort((a, b) => b.orderRef.createdAt <=> a.orderRef.createdAt) %}
                            {% set order = orderItem.orderRef %}
                            <tr>
                                <td>
                                    <a href="{{ path('staff_order_manage', {'id': order.id}) }}" 
                                       class="text-decoration-none">
                                        <strong>{{ order.orderNumber }}</strong>
                                    </a>
                                    {% if order.isUrgent %}
                                        <span class="badge bg-danger ms-1">Urgent</span>
                                    {% endif %}
                                </td>
                                <td>{{ order.createdAt|date('M d, Y') }}</td>
                                <td>{{ order.customer.fullName|default('N/A') }}</td>
                                <td>{{ orderItem.quantity }}</td>
                                <td class="fw-bold">₱{{ orderItem.totalPrice|number_format(2) }}</td>
                                <td>
                                    <span class="badge bg-{{ order.status == 'completed' ? 'success' : (order.status == 'pending' ? 'warning' : (order.status == 'processing' ? 'info' : (order.status == 'cancelled' ? 'secondary' : 'danger'))) }}">
                                        {{ order.status|title }}
                                    </span>
                                </td>
                                <td>
                                    <a href="{{ path('staff_order_manage', {'id': order.id}) }}" 
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% if product.orderItems|length > 10 %}
                <div class="text-center mt-3">
                    <a href="#" class="btn btn-sm btn-outline-secondary">
                        View All {{ product.orderItems|length }} Orders
                    </a>
                </div>
                {% endif %}
            </div>
        </div>
        {% endif %}
    </div>
    
    <!-- Right Sidebar -->
    <div class="col-lg-4">
        <!-- Quick Actions Card -->
        <div class="card admin-chart mb-4">
            <div class="card-header bg-white border-0">
                <h5 class="mb-0">Quick Actions</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="{{ path('staff_product_edit', {'id': product.id}) }}" 
                       class="btn btn-primary">
                        <i class="bi bi-pencil me-2"></i>Edit Product
                    </a>
                    
                    {% if product.isActive %}
                        <button type="button" class="btn btn-warning" 
                                onclick="toggleProductStatus({{ product.id }}, true)">
                            <i class="bi bi-pause-circle me-2"></i>Mark as Unavailable
                        </button>
                    {% else %}
                        <button type="button" class="btn btn-success" 
                                onclick="toggleProductStatus({{ product.id }}, false)">
                            <i class="bi bi-play-circle me-2"></i>Mark as Available
                        </button>
                    {% endif %}
                    
                    <button type="button" class="btn btn-danger" 
                            onclick="confirmDeleteProduct({{ product.id }}, '{{ product.name|e('js') }}')">
                        <i class="bi bi-trash me-2"></i>Delete Product
                    </button>
                </div>
                
                <hr class="my-4">
                
                <!-- Related Actions -->
                <h6 class="mb-3">Related Actions</h6>
                <div class="d-grid gap-2">
                    {% if product.stock %}
                        <a href="{{ path('staff_stock_update', {'id': product.stock.id}) }}" 
                           class="btn btn-outline-primary text-start">
                            <i class="bi bi-box-arrow-in-down me-2"></i>Update Stock
                        </a>
                    {% else %}
                        <a href="{{ path('staff_stock_add') }}?product={{ product.id }}" 
                           class="btn btn-outline-success text-start">
                            <i class="bi bi-plus-circle me-2"></i>Add Stock
                        </a>
                    {% endif %}
                    
                    <a href="{{ path('staff_order_new') }}" 
                       class="btn btn-outline-secondary text-start">
                        <i class="bi bi-cart-plus me-2"></i>Create Order with this Product
                    </a>
                    
                    <a href="{{ path('staff_product_new') }}" 
                       class="btn btn-outline-info text-start">
                        <i class="bi bi-copy me-2"></i>Duplicate Product
                    </a>
                </div>
            </div>
        </div>
        
        <!-- Product Statistics Card -->
        <div class="card admin-chart mb-4">
            <div class="card-header bg-white border-0">
                <h5 class="mb-0">Product Statistics</h5>
            </div>
            <div class="card-body">
                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <div class="bg-light p-3 rounded text-center">
                            <h6 class="text-muted mb-1">Total Sold</h6>
                            <h3 class="fw-bold mb-0">{{ product.totalSold|default(0) }}</h3>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="bg-light p-3 rounded text-center">
                            <h6 class="text-muted mb-1">Revenue</h6>
                            <h3 class="fw-bold mb-0">₱{{ (product.totalSold|default(0) * product.price)|number_format(2) }}</h3>
                        </div>
                    </div>
                </div>
                
                <div class="progress mb-3" style="height: 10px;">
                    {% if product.stock %}
                        {% set stockPercentage = (product.totalSold|default(0) / (product.totalSold|default(0) + product.stock.quantity)) * 100 %}
                        <div class="progress-bar bg-success" role="progressbar" 
                             style="width: {{ stockPercentage|round }}%" 
                             aria-valuenow="{{ stockPercentage|round }}" 
                             aria-valuemin="0" aria-valuemax="100">
                        </div>
                    {% endif %}
                </div>
                <small class="text-muted">
                    {% if product.stock %}
                        {{ product.totalSold|default(0) }} sold / {{ product.totalSold|default(0) + product.stock.quantity }} total units
                    {% else %}
                        {{ product.totalSold|default(0) }} units sold
                    {% endif %}
                </small>
                
                <hr class="my-4">
                
                <!-- Product Timeline -->
                <h6 class="mb-3">Product Timeline</h6>
                <div class="timeline">
                    <div class="timeline-item">
                        <div class="timeline-marker bg-primary"></div>
                        <div class="timeline-content">
                            <h6 class="mb-0">Product Created</h6>
                            <small class="text-muted">{{ product.createdAt|date('F j, Y h:i A') }}</small>
                        </div>
                    </div>
                    {% if product.updatedAt and product.updatedAt != product.createdAt %}
                    <div class="timeline-item">
                        <div class="timeline-marker bg-warning"></div>
                        <div class="timeline-content">
                            <h6 class="mb-0">Last Updated</h6>
                            <small class="text-muted">{{ product.updatedAt|date('F j, Y h:i A') }}</small>
                        </div>
                    </div>
                    {% endif %}
                    {% if product.firstOrderDate %}
                    <div class="timeline-item">
                        <div class="timeline-marker bg-success"></div>
                        <div class="timeline-content">
                            <h6 class="mb-0">First Sale</h6>
                            <small class="text-muted">{{ product.firstOrderDate|date('F j, Y') }}</small>
                        </div>
                    </div>
                    {% endif %}
                    {% if product.lastOrderDate %}
                    <div class="timeline-item">
                        <div class="timeline-marker bg-info"></div>
                        <div class="timeline-content">
                            <h6 class="mb-0">Last Sale</h6>
                            <small class="text-muted">{{ product.lastOrderDate|date('F j, Y') }}</small>
                        </div>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
        
        <!-- Product Details Card -->
        <div class="card admin-chart">
            <div class="card-header bg-white border-0">
                <h5 class="mb-0">Product Details</h5>
            </div>
            <div class="card-body">
                <table class="table table-sm table-borderless">
                    <tr>
                        <th class="text-muted" width="40%">ID:</th>
                        <td>#{{ product.id }}</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Status:</th>
                        <td>
                            {% if product.isActive %}
                                <span class="badge bg-success">Active</span>
                            {% else %}
                                <span class="badge bg-danger">Inactive</span>
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <th class="text-muted">Featured:</th>
                        <td>
                            {% if product.isFeatured|default(false) %}
                                <span class="badge bg-warning">Yes</span>
                            {% else %}
                                <span class="badge bg-secondary">No</span>
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <th class="text-muted">Created By:</th>
                        <td>{{ product.createdBy.fullName|default('System') }}</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Category:</th>
                        <td>{{ product.category.name|default('Uncategorized') }}</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Type:</th>
                        <td>{{ product.type.name|default('N/A') }}</td>
                    </tr>
                    {% if product.tags %}
                    <tr>
                        <th class="text-muted">Tags:</th>
                        <td>
                            <div class="d-flex flex-wrap gap-1">
                                {% for tag in product.tags|split(',') %}
                                    <span class="badge bg-light text-dark">{{ tag|trim }}</span>
                                {% endfor %}
                            </div>
                        </td>
                    </tr>
                    {% endif %}
                </table>
                
                <hr class="my-3">
                
                <!-- Share/Export Options -->
                <h6 class="mb-3">Share & Export</h6>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="copyProductLink()">
                        <i class="bi bi-link me-1"></i>Copy Link
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="exportProductDetails()">
                        <i class="bi bi-download me-1"></i>Export
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-info" onclick="printProductDetails()">
                        <i class="bi bi-printer me-1"></i>Print
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Image Modal -->
<div class="modal fade" id="imageModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">{{ product.name }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <img id="modalImage" src="" alt="{{ product.name }}" class="img-fluid">
            </div>
            <div class="modal-footer">
                <a href="#" id="downloadImage" class="btn btn-primary" download>
                    <i class="bi bi-download me-2"></i>Download
                </a>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// Product status toggle
function toggleProductStatus(productId, currentStatus) {
    const action = currentStatus ? 'deactivate' : 'activate';
    if (confirm(`Are you sure you want to ${action} this product?`)) {
        const formData = new FormData();
        formData.append('_token', '{{ csrf_token("toggle-status") }}' + productId);
        
        fetch(`/staff/products/${productId}/toggle-status`, {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert('Error: ' + data.message);
            }
        })
        .catch(error => {
            alert('Error: ' + error.message);
        });
    }
}

// Delete product
function confirmDeleteProduct(productId, productName) {
    if (confirm(`Are you sure you want to delete "${productName}"? This action cannot be undone.`)) {
        const formData = new FormData();
        formData.append('_token', '{{ csrf_token("delete") }}' + productId);
        
        fetch(`/staff/products/${productId}/delete`, {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert(data.message);
                if (data.redirect) {
                    window.location.href = data.redirect;
                } else {
                    window.location.href = '{{ path('staff_products') }}';
                }
            } else {
                alert('Error: ' + data.message);
            }
        })
        .catch(error => {
            alert('Error deleting product: ' + error.message);
        });
    }
}

// Image modal
function openImageModal(imageUrl) {
    const modalImage = document.getElementById('modalImage');
    const downloadLink = document.getElementById('downloadImage');
    
    modalImage.src = imageUrl;
    downloadLink.href = imageUrl;
    downloadLink.download = '{{ product.name|slug }}.jpg';
    
    new bootstrap.Modal(document.getElementById('imageModal')).show();
}

// Copy to clipboard
function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(() => {
        const originalButton = event.target.closest('button');
        const originalHTML = originalButton.innerHTML;
        originalButton.innerHTML = '<i class="bi bi-check"></i>';
        originalButton.classList.remove('btn-outline-secondary');
        originalButton.classList.add('btn-outline-success');
        
        setTimeout(() => {
            originalButton.innerHTML = originalHTML;
            originalButton.classList.remove('btn-outline-success');
            originalButton.classList.add('btn-outline-secondary');
        }, 2000);
    }).catch(err => {
        alert('Failed to copy: ' + err);
    });
}

function copyProductLink() {
    const url = window.location.href;
    copyToClipboard(url);
}

// Export product details
function exportProductDetails() {
    const productData = {
        name: '{{ product.name }}',
        sku: '{{ product.sku|default("N/A") }}',
        price: '₱{{ product.price|number_format(2) }}',
        costPrice: '{{ product.costPrice ? "₱" ~ product.costPrice|number_format(2) : "N/A" }}',
        category: '{{ product.category.name|default("Uncategorized") }}',
        type: '{{ product.type.name|default("N/A") }}',
        stock: '{{ product.stock ? product.stock.quantity : 0 }}',
        totalSold: '{{ product.totalSold|default(0) }}',
        status: '{{ product.isActive ? "Active" : "Inactive" }}',
        description: '{{ product.description|default("")|replace({"\n": " ", "\r": " "}) }}',
        created: '{{ product.createdAt|date("Y-m-d H:i:s") }}',
        lastUpdated: '{{ product.updatedAt|date("Y-m-d H:i:s") }}'
    };
    
    let csv = 'Field,Value\n';
    Object.entries(productData).forEach(([key, value]) => {
        csv += `${key},"${value}"\n`;
    });
    
    const blob = new Blob([csv], { type: 'text/csv' });
    const url = window.URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `product_{{ product.sku|default(product.id) }}_details.csv`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    window.URL.revokeObjectURL(url);
}

// Print product details
function printProductDetails() {
    const printContent = document.querySelector('.col-lg-8').innerHTML;
    const originalContent = document.body.innerHTML;
    
    document.body.innerHTML = `
        <div class="container mt-4">
            <div class="text-center mb-4">
                <h2>{{ product.name }}</h2>
                <p class="text-muted">Product Details - SMSol Studio</p>
                <p>Generated: ${new Date().toLocaleString()}</p>
            </div>
            ${printContent}
        </div>
    `;
    
    window.print();
    document.body.innerHTML = originalContent;
    location.reload();
}
</script>

