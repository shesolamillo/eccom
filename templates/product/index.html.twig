{# templates/product/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Products - SMSol Studio{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .product-card {
            transition: all 0.3s ease;
            border: 1px solid #e9ecef;
            border-radius: 12px;
            overflow: hidden;
            height: 100%;
        }
        
        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }
        
        .product-image-container {
            height: 220px;
            background: #f8f9fa;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }
        
        .product-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.3s ease;
        }
        
        .product-card:hover .product-image {
            transform: scale(1.05);
        }
        
        .product-price {
            color: #667eea;
            font-weight: 700;
            font-size: 1.25rem;
        }
        
        .stock-badge {
            font-size: 0.75rem;
            padding: 0.25rem 0.5rem;
        }
        
        .product-title {
            font-size: 1.1rem;
            font-weight: 600;
            color: #333;
            margin-bottom: 0.5rem;
        }
        
        .product-description {
            font-size: 0.875rem;
            color: #6c757d;
            line-height: 1.5;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container py-4">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="fw-bold mb-2">Our Products</h1>
                    <p class="text-muted mb-0">Browse our curated collection of fashion items</p>
                </div>
                {% if is_granted('ROLE_STAFF') %}
                <a href="{{ path('staff_product_new') }}" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-2"></i>Add Product
                </a>
                {% endif %}
            </div>
        </div>
    </div>
    
    <!-- Filters -->
    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Category</label>
                    <select name="category" class="form-select">
                        <option value="">All Categories</option>
                        {% for category in categories %}
                            <option value="{{ category.id }}" {{ selectedCategory == category.id ? 'selected' : '' }}>
                                {{ category.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Product Type</label>
                    <select name="type" class="form-select">
                        <option value="">All Types</option>
                        {% for type in types %}
                            <option value="{{ type.id }}" {{ selectedType == type.id ? 'selected' : '' }}>
                                {{ type.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">
                        <i class="bi bi-funnel me-2"></i>Filter
                    </button>
                    <a href="{{ path('app_products') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-2"></i>Clear
                    </a>
                </div>
            </form>
        </div>
    </div>
    
    <!-- Products Grid -->
    <div class="row g-4">
        {% for product in products %}
        <div class="col-xl-3 col-lg-4 col-md-6 col-sm-6">
            <div class="card product-card h-100">
                <!-- Product Image -->
                <div class="product-image-container position-relative">
                    {% if product.photo %}
                        <img src="{{ asset('uploads/products/' ~ product.photo) }}" 
                             alt="{{ product.name }}" 
                             class="product-image">
                    {% else %}
                        <div class="text-center text-muted">
                            <i class="bi bi-image display-4"></i>
                            <p class="mt-2">No Image</p>
                        </div>
                    {% endif %}
                    
                    <!-- Stock Badge -->
                    {% if product.stock %}
                        {% if product.stock.quantity <= 0 %}
                            <span class="position-absolute top-0 start-0 m-2 badge bg-danger stock-badge">
                                Out of Stock
                            </span>
                        {% elseif product.stock.quantity < 10 %}
                            <span class="position-absolute top-0 start-0 m-2 badge bg-warning stock-badge">
                                Low Stock
                            </span>
                        {% endif %}
                    {% endif %}
                </div>
                
                <!-- Card Body -->
                <div class="card-body d-flex flex-column">
                    <!-- Product Title -->
                    <h5 class="product-title">{{ product.name }}</h5>
                    
                    <!-- Product Description -->
                    <p class="product-description mb-3 flex-grow-1">
                        {{ product.description|slice(0, 80) }}{% if product.description|length > 80 %}...{% endif %}
                    </p>
                    
                    <!-- Price and Stock -->
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="product-price">₱{{ product.price|number_format(2) }}</div>
                        {% if product.stock and product.stock.quantity > 0 %}
                            <span class="badge bg-success stock-badge">
                                {{ product.stock.quantity }} in stock
                            </span>
                        {% endif %}
                    </div>
                    
                    <!-- Category Badges -->
                    <div class="mb-3">
                        {% if product.productType %}
                            <span class="badge bg-info me-1">{{ product.productType.name }}</span>
                        {% endif %}
                        {% if product.clothesCategory %}
                            <span class="badge bg-secondary">{{ product.clothesCategory.name }}</span>
                        {% endif %}
                    </div>
                    
                    <!-- Action Buttons -->
                    <div class="d-grid gap-2 mt-auto">
                        <a href="{{ path('app_product_show', {'id': product.id}) }}" 
                           class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-eye me-1"></i>View Details
                        </a>
                        
                        {% if is_granted('ROLE_USER') and product.isAvailable and product.stock and product.stock.quantity > 0 %}
                            <a href="{{ path('app_user_order_create') }}?product={{ product.id }}" 
                               class="btn btn-primary btn-sm">
                                <i class="bi bi-cart-plus me-1"></i>Order Now
                            </a>
                        {% elseif not product.isAvailable %}
                            <button class="btn btn-secondary btn-sm" disabled>
                                <i class="bi bi-slash-circle me-1"></i>Unavailable
                            </button>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        {% else %}
        <!-- Empty State -->
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center py-5">
                    <i class="bi bi-bag-x display-1 text-muted mb-3"></i>
                    <h4 class="text-muted mb-2">No products found</h4>
                    <p class="text-muted mb-4">Try adjusting your filters or check back later</p>
                    {% if is_granted('ROLE_STAFF') %}
                        <a href="{{ path('staff_product_new') }}" class="btn btn-primary">
                            <i class="bi bi-plus-circle me-2"></i>Add Your First Product
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    
    <!-- Pagination -->
    {% if products|length > 0 %}
    <nav aria-label="Page navigation" class="mt-5">
        <ul class="pagination justify-content-center">
            <li class="page-item disabled">
                <a class="page-link" href="#" tabindex="-1">Previous</a>
            </li>
            <li class="page-item active"><a class="page-link" href="#">1</a></li>
            <li class="page-item"><a class="page-link" href="#">2</a></li>
            <li class="page-item"><a class="page-link" href="#">3</a></li>
            <li class="page-item">
                <a class="page-link" href="#">Next</a>
            </li>
        </ul>
    </nav>
    {% endif %}
</div>
{% endblock %}