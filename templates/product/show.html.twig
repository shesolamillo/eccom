{# templates/product/show.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}{{ product.name }} - SMSol Studio{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row">
        <!-- Product Images -->
        <div class="col-lg-6 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <div class="product-image-main text-center mb-3">
                        {% if product.image %}
                            <img src="{{ asset('uploads/products/' ~ product.image) }}" 
                                 alt="{{ product.name }}" class="img-fluid rounded" style="max-height: 400px;">
                        {% else %}
                            <div class="bg-light d-flex align-items-center justify-content-center rounded" 
                                 style="height: 400px;">
                                <i class="bi bi-image text-muted display-1"></i>
                            </div>
                        {% endif %}
                    </div>
                    
                    {% if product.image %}
                    <div class="product-thumbnails d-flex justify-content-center gap-2">
                        <div class="thumbnail active border rounded p-2" style="width: 80px; height: 80px;">
                            <img src="{{ asset('uploads/products/' ~ product.image) }}" 
                                 alt="Thumbnail" class="img-fluid h-100">
                        </div>
                        <!-- Additional thumbnails can be added here -->
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
        
        <!-- Product Info -->
        <div class="col-lg-6">
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_products') }}">Products</a></li>
                    <li class="breadcrumb-item active">{{ product.name }}</li>
                </ol>
            </nav>
            
            <h1 class="fw-bold mb-2">{{ product.name }}</h1>
            
            <div class="d-flex align-items-center mb-3">
                <div class="rating me-3">
                    <i class="bi bi-star-fill text-warning"></i>
                    <i class="bi bi-star-fill text-warning"></i>
                    <i class="bi bi-star-fill text-warning"></i>
                    <i class="bi bi-star-fill text-warning"></i>
                    <i class="bi bi-star-half text-warning"></i>
                    <span class="ms-2 text-muted">(24 reviews)</span>
                </div>
                <span class="badge bg-success">In Stock</span>
            </div>
            
            <h2 class="text-primary fw-bold mb-4">₱{{ product.price|number_format(2) }}</h2>
            
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">Product Details</h5>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <strong>Category:</strong> {{ product.category.name|default('N/A') }}
                        </div>
                        <div class="col-md-6 mb-2">
                            <strong>Type:</strong> {{ product.productType.name|default('N/A') }}
                        </div>
                        <div class="col-md-6 mb-2">
                            <strong>Stock:</strong> {{ product.stock.quantity|default(0) }} units
                        </div>
                        <div class="col-md-6 mb-2">
                            <strong>SKU:</strong> {{ product.sku|default('N/A') }}
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">Description</h5>
                    <p class="card-text">{{ product.description|default('No description available.') }}</p>
                </div>
            </div>
            
            <div class="d-grid gap-2">
                {% if is_granted('ROLE_USER') and product.isAvailable %}
                    <a href="{{ path('app_user_order_create') }}?product={{ product.id }}" 
                       class="btn btn-primary btn-lg">
                        <i class="bi bi-cart-plus me-2"></i>Order Now
                    </a>
                {% elseif not is_granted('ROLE_USER') %}
                    <a href="{{ path('app_login') }}" class="btn btn-primary btn-lg">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Login to Order
                    </a>
                {% else %}
                    <button class="btn btn-secondary btn-lg" disabled>
                        <i class="bi bi-cart-x me-2"></i>Out of Stock
                    </button>
                {% endif %}
                
                {% if is_granted('ROLE_STAFF') %}
                    <a href="{{ path('staff_product_edit', {'id': product.id}) }}" 
                       class="btn btn-outline-primary">
                        <i class="bi bi-pencil me-2"></i>Edit Product
                    </a>
                {% endif %}
            </div>
        </div>
    </div>
    
    <!-- Related Products -->
    {% if relatedProducts|default([])|length > 0 %}
    <div class="mt-5">
        <h3 class="fw-bold mb-4">Related Products</h3>
        <div class="row">
            {% for related in relatedProducts %}
            <div class="col-md-3 mb-4">
                <div class="card product-card h-100">
                    <div class="card-img-top bg-light d-flex align-items-center justify-content-center" 
                         style="height: 150px;">
                        {% if related.image %}
                            <img src="{{ asset('uploads/products/' ~ related.image) }}" 
                                 alt="{{ related.name }}" class="img-fluid" style="max-height: 150px;">
                        {% else %}
                            <i class="bi bi-image text-muted fs-1"></i>
                        {% endif %}
                    </div>
                    <div class="card-body">
                        <h6 class="card-title">{{ related.name }}</h6>
                        <p class="card-text text-primary fw-bold mb-2">₱{{ related.price|number_format(2) }}</p>
                        <a href="{{ path('app_product_show', {'id': related.id}) }}" 
                           class="btn btn-sm btn-outline-primary w-100">
                            View Details
                        </a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}