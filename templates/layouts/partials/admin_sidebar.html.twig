{# templates/layouts/partials/admin_sidebar.html.twig #}
<div class="admin-sidebar h-100">
    <div class="sidebar-header">
        <div class="d-flex align-items-center">
            {% if app.user.userProfile and app.user.userProfile.profilePicture %}
                <img src="{{ asset('uploads/profiles/' ~ app.user.userProfile.profilePicture) }}" 
                     alt="Profile" class="rounded-circle me-3" width="45" height="45">
            {% else %}
                <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center me-3" 
                     style="width: 45px; height: 45px;">
                    <i class="bi bi-person text-white"></i>
                </div>
            {% endif %}
            <div>
                <h6 class="mb-0">{{ app.user.firstName }} {{ app.user.lastName }}</h6>
                <small class="text-muted">
                    {% if is_granted('ROLE_ADMIN') %}
                        Administrator
                    {% elseif is_granted('ROLE_STAFF') %}
                        Staff Member
                    {% endif %}
                </small>
            </div>
        </div>
    </div>
    
    <div class="sidebar-menu">
        <nav class="nav flex-column">
            {# Dashboard - Show to both Admin and Staff #}
            <a href="{{ path('admin_dashboard') }}" 
               class="nav-link {{ app.request.get('_route') == 'admin_dashboard' ? 'active' : '' }}">
                <i class="bi bi-speedometer2"></i>Dashboard
            </a>
            
            {# Analytics - Hide from Staff #}
            {% if is_granted('ROLE_ADMIN') %}
                {# <a href="{{ path('admin_analytics') }}" 
                   class="nav-link {{ app.request.get('_route') == 'admin_analytics' ? 'active' : '' }}">
                    <i class="bi bi-bar-chart"></i>Analytics
                </a> #}
            {% endif %}
            
            {# Users - Admin only #}
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('admin_users') }}" 
                   class="nav-link {{ app.request.get('_route') in ['admin_users', 'admin_user_edit'] ? 'active' : '' }}">
                    <i class="bi bi-people"></i>Users
                </a>
            {% endif %}
            
            {# Cart - Role based (Create Orders) #}
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('admin_order_new') }}" 
                   class="nav-link {{ app.request.get('_route') == 'admin_order_new' ? 'active' : '' }}" title="Create Order via Cart">
                    <i class="bi bi-bag-check"></i>Cart
                </a>
            {% elseif is_granted('ROLE_STAFF') %}
                <a href="{{ path('staff_order_new') }}" 
                   class="nav-link {{ app.request.get('_route') == 'staff_order_new' ? 'active' : '' }}" title="Create Order via Cart">
                    <i class="bi bi-bag-check"></i>Cart
                </a>
            {% endif %}
            
            {# Orders - Role based (View/Manage Orders) #}
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('admin_orders') }}" 
                   class="nav-link {{ app.request.get('_route') in ['admin_orders', 'admin_order_manage', 'admin_order_show'] ? 'active' : '' }}">
                    <i class="bi bi-list-check"></i>Orders
                </a>
            {% elseif is_granted('ROLE_STAFF') %}
                <a href="{{ path('staff_orders') }}" 
                   class="nav-link {{ app.request.get('_route') in ['staff_orders', 'staff_order_manage'] ? 'active' : '' }}">
                    <i class="bi bi-list-check"></i>Orders
                </a>
            {% endif %}
            
            {# Products - Role based #}
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('admin_products') }}" 
                   class="nav-link {{ app.request.get('_route') in ['admin_products', 'admin_product_new', 'admin_product_edit', 'admin_product_show'] ? 'active' : '' }}">
                    <i class="bi bi-shop"></i>Products
                </a>
            {% elseif is_granted('ROLE_STAFF') %}
                <a href="{{ path('staff_products') }}" 
                   class="nav-link {{ app.request.get('_route') in ['staff_products', 'staff_product_new', 'staff_product_edit'] ? 'active' : '' }}">
                    <i class="bi bi-shop"></i>Products
                </a>
            {% endif %}
            
            {# Stocks - Role based #}
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('staff_stocks') }}" 
                   class="nav-link {{ app.request.get('_route') in ['staff_stocks', 'staff_stock_update', 'staff_stock_add'] ? 'active' : '' }}">
                    <i class="bi bi-box-seam"></i>Stocks
                </a>
            {% elseif is_granted('ROLE_STAFF') %}
                <a href="{{ path('staff_stocks') }}" 
                   class="nav-link {{ app.request.get('_route') in ['staff_stocks', 'staff_stock_update', 'staff_stock_add'] ? 'active' : '' }}">
                    <i class="bi bi-box-seam"></i>Stocks
                </a>
            {% endif %}
            
            {# Activity Logs - Admin only #}
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('admin_activity_logs') }}" 
                   class="nav-link {{ app.request.get('_route') == 'admin_activity_logs' ? 'active' : '' }}">
                    <i class="bi bi-list-check"></i>Activity Logs
                </a>
            {% endif %}
            
            <div class="mt-4 pt-3 border-top">
                <h6 class="nav-link">
                    <i class="bi bi-house"></i>LOGOUT
                </h6>
                
                <a href="{{ path('app_logout') }}" class="nav-link text-danger">
                    <i class="bi bi-box-arrow-right"></i>Logout
                </a>
            </div>
        </nav>
    </div>
</div>