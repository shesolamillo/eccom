{% extends 'layouts/admin.html.twig' %}

{% block title %}Product Management{% endblock %}

{% block page_title %}Product Management{% endblock %}
{% block page_description %}Manage your products{% endblock %}

{% block admin_content %}
<div class="card">
    <div class="card-header bg-white">
        <h5 class="mb-0">All Products</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </thead>
                <tbody>
                    {% for product in products %}
                    <tr>
                        <td>{{ product.id }}</td>
                        <td>{{ product.name }}</td>
                        <td>{{ product.clothesCategory.name|default('N/A') }}</td>
                        <td>₱{{ product.price|number_format(2) }}</td>
                        <td>{{ product.stock.quantity|default(0) }}</td>
                        <td>{{ product.isAvailable ? 'Available' : 'Unavailable' }}</td>
                        <td>
                            <a href="{{ path('admin_product_edit', {'id': product.id}) }}" class="btn btn-sm btn-primary">Edit</a>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="7" class="text-center">No products found.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}