{% extends 'layouts/admin.html.twig' %}

{% block title %}Edit Product - {{ product.name }}{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('admin_products') }}">Products</a></li>
<li class="breadcrumb-item active">Edit</li>
{% endblock %}

{% block page_title %}Edit Product{% endblock %}
{% block page_description %}Update product information{% endblock %}

{% block admin_content %}
<div class="card">
    <div class="card-header bg-white">
        <h5 class="mb-0">Product Details</h5>
    </div>
    <div class="card-body">
        {{ form_start(form) }}
            <div class="row">
                <div class="col-md-6 mb-3">
                    {{ form_row(form.name) }}
                </div>
                <div class="col-md-6 mb-3">
                    {{ form_row(form.sku) }}
                </div>
                <div class="col-md-6 mb-3">
                    {{ form_row(form.price) }}
                </div>
                <div class="col-md-6 mb-3">
                    {{ form_row(form.costPrice) }}
                </div>
                <div class="col-12 mb-3">
                    {{ form_row(form.description) }}
                </div>
                <div class="col-md-6 mb-3">
                    {{ form_row(form.productType) }}
                </div>
                <div class="col-md-6 mb-3">
                    {{ form_row(form.clothesCategory) }}
                </div>
                <div class="col-12 mb-3">
                    {{ form_row(form.photo) }}
                    {% if product.photo %}
                        <div class="mt-2">
                            <img src="{{ asset('uploads/products/' ~ product.photo) }}" alt="{{ product.name }}" style="max-height: 150px;">
                        </div>
                    {% endif %}
                </div>
                <div class="col-12 mb-3">
                    {{ form_row(form.isAvailable) }}
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a href="{{ path('admin_products') }}" class="btn btn-secondary">Cancel</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}