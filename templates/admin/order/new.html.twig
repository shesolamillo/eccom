{% extends 'layouts/admin.html.twig' %}

{% block title %}Create New Order - Admin{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('admin_orders') }}">Orders</a></li>
<li class="breadcrumb-item active">New Order</li>
{% endblock %}

{% block page_title %}Create New Order{% endblock %}
{% block page_description %}Create an order for yourself - step by step{% endblock %}

{% block admin_content %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/cartcheckout.css') }}">
{% endblock %}

<!-- Progress Steps -->
<input type="hidden" name="_csrf_token" value="{{ csrf_token('order_create') }}">
<input type="hidden" name="customer_id" id="customerId" value="{{ app.user.id }}">
<div class="checkout-steps">
    <div class="step-item active" id="step1Item">
        <div class="step-circle active">
            <span class="step-number">1</span>
            <i class="bi bi-check step-check"></i>
        </div>
        <div class="step-label">Cart</div>
    </div>
    <div class="step-connector" id="connector1"></div>

    <div class="step-item" id="step2Item">
        <div class="step-circle">
            <span class="step-number">2</span>
            <i class="bi bi-check step-check"></i>
        </div>
        <div class="step-label">Address</div>
    </div>
    <div class="step-connector" id="connector2"></div>

    <div class="step-item" id="step3Item">
        <div class="step-circle">
            <span class="step-number">3</span>
            <i class="bi bi-check step-check"></i>
        </div>
        <div class="step-label">Payment</div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="checkout-main" style="position: relative;">
            <!-- Step 1: Shopping Cart -->
            <div class="checkout-step active" id="stepCart">
                <h2 class="step-title"><i class="bi bi-cart3 me-2"></i>Shopping Cart</h2>
                
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>Add products to the cart. You're creating an order for {{ app.user.firstName }} {{ app.user.lastName }}.
                </div>

                <!-- Hidden customer ID (current logged-in user) -->
                <input type="hidden" name="customer_id" id="customerId" value="{{ app.user.id }}">

                <!-- Search & Filter -->
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label">Search Products</label>
                        <input type="text" id="productSearch" class="form-control" placeholder="Search product name...">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Filter by Category</label>
                        <select id="categoryFilter" class="form-select">
                            <option value="">All Categories</option>
                            {% for category in categories %}
                                <option value="{{ category.id }}">{{ category.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>

                <!-- Product Grid -->
                <div class="row g-3 mb-4" id="productGrid">
                    {% for product in products %}
                        <div class="col-md-6">
                            <div class="card border h-100">
                                <div class="card-body">
                                    <div class="d-flex align-items-start mb-2">
                                        {% if product.photoUrl %}
                                            <img src="{{ product.photoUrl }}" alt="{{ product.name }}" 
                                                 class="rounded me-3" style="width: 70px; height: 70px; object-fit: cover;">
                                        {% else %}
                                            <div class="bg-light rounded me-3 d-flex align-items-center justify-content-center"
                                                 style="width: 70px; height: 70px;">
                                                <i class="bi bi-image"></i>
                                            </div>
                                        {% endif %}
                                        <div class="flex-grow-1">
                                            <h6 class="mb-1">{{ product.name }}</h6>
                                            <p class="text-muted mb-0 small">{{ product.productType.name }}</p>
                                        </div>
                                    </div>

                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <strong>₱{{ product.price|number_format(2) }}</strong>
                                        {% if product.stock %}
                                            <span class="badge bg-info">{{ product.stock.quantity }} stock</span>
                                        {% endif %}
                                    </div>

                                    <!-- Add to Cart -->
                                    <div class="input-group input-group-sm">
                                        <input type="number" class="form-control product-qty" value="1" min="1" 
                                               data-product-id="{{ product.id }}" data-price="{{ product.price }}">
                                        <button class="btn btn-success btn-add-to-cart" type="button" 
                                                data-product-id="{{ product.id }}" data-product-name="{{ product.name }}">
                                            <i class="bi bi-plus"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>

                <div class="btn-group-navigation">
                    <a href="{{ path('admin_orders') }}" class="btn btn-secondary">
                        <i class="bi bi-x-circle me-2"></i>Cancel
                    </a>
                    <button class="btn btn-primary" onclick="goToStep(2)">
                        Next: Shipping Address <i class="bi bi-arrow-right ms-2"></i>
                    </button>
                </div>
            </div>

            <!-- Step 2: Shipping Address -->
            <div class="checkout-step" id="stepAddress">
           
                <h2 class="step-title"><i class="bi bi-geo-alt me-2"></i>Shipping Address</h2>
                
                <!-- User's Current Address Information -->
                <div class="card mb-4 border-primary">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-person-circle me-2"></i>Your Current Address Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <p class="mb-2"><strong>Name:</strong><br>
                                <span class="text-muted">{{ app.user.firstName }} {{ app.user.lastName }}</span></p>
                                <p class="mb-2"><strong>Phone:</strong><br>
                                <span class="text-muted">{{ app.user.phoneNumber|default('Not set') }}</span></p>
                            </div>
                            <div class="col-md-6">
                                <p class="mb-2"><strong>Address:</strong><br>
                                <span class="text-muted">{% if currentUser.userProfile and currentUser.userProfile.address %}{{ currentUser.userProfile.address }}{% else %}<em class="text-danger">Not set</em>{% endif %}</span></p>
                                <p class="mb-0"><strong>City:</strong><br>
                                <span class="text-muted">{% if currentUser.userProfile and currentUser.userProfile.city %}{{ currentUser.userProfile.city }}{% else %}<em class="text-danger">Not set</em>{% endif %}</span></p>
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-md-6">
                                <p class="mb-0"><strong>State/Province:</strong><br>
                                <span class="text-muted">{% if currentUser.userProfile and currentUser.userProfile.state %}{{ currentUser.userProfile.state }}{% else %}<em class="text-danger">Not set</em>{% endif %}</span></p>
                            </div>
                            <div class="col-md-6">
                                <p class="mb-0"><strong>Postal Code:</strong><br>
                                <span class="text-muted">{% if currentUser.userProfile and currentUser.userProfile.zipCode %}{{ currentUser.userProfile.zipCode }}{% else %}<em class="text-danger">Not set</em>{% endif %}</span></p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>Select delivery type and fill in shipping details below.
                </div>

                <form id="addressForm" class="row g-3">
                    <!-- Delivery Type -->
                    <div class="col-md-6">
                        <label class="form-label">Delivery Type <span class="text-danger">*</span></label>
                        <select name="delivery_type" id="deliveryType" class="form-select" onchange="updateDeliveryFields()" required>
                            <option value="">-- Select delivery type --</option>
                            <option value="pickup">Pickup</option>
                            <option value="delivery">Delivery</option>
                        </select>
                    </div>
                    
                    <div class="col-md-6">
                        <div class="form-check form-switch mt-4">
                            <input type="checkbox" name="is_urgent" id="isUrgent" class="form-check-input">
                            <label class="form-check-label" for="isUrgent">
                                <i class="bi bi-lightning me-1"></i>Mark as urgent order
                            </label>
                        </div>
                    </div>
                    
                    <!-- Delivery Address Fields (Hidden until delivery is selected) -->
                    <div id="deliveryAddressSection" style="display: none;" class="w-100">
                        <h5 class="mb-3 mt-2"><i class="bi bi-house-door me-2"></i>Delivery Address Information</h5>
                        
                        <div class="row g-3">
                            <!-- Recipient Name -->
                            <div class="col-12">
                                <label class="form-label">Recipient Name <span class="text-danger">*</span></label>
                                <input type="text" name="recipient_name" class="form-control" placeholder="Full name of recipient" required>
                            </div>
                            
                            <!-- Phone Number -->
                            <div class="col-md-6">
                                <label class="form-label">Phone Number <span class="text-danger">*</span></label>
                                <input type="tel" name="phone_number" class="form-control" placeholder="+63 9XX XXX XXXX" required>
                            </div>
                            
                            <!-- Street Address -->
                            <div class="col-12">
                                <label class="form-label">Street Address <span class="text-danger">*</span></label>
                                <input type="text" name="street_address" class="form-control" placeholder="e.g., 123 Main Street, Apt 4B" required>
                            </div>
                            
                            <!-- City/Municipality -->
                            <div class="col-md-6">
                                <label class="form-label">City/Municipality <span class="text-danger">*</span></label>
                                <input type="text" name="city" class="form-control" placeholder="City or municipality" required>
                            </div>
                            
                            <!-- Postal Code -->
                            <div class="col-md-6">
                                <label class="form-label">Postal Code <span class="text-danger">*</span></label>
                                <input type="text" name="postal_code" class="form-control" placeholder="e.g., 1234" required>
                            </div>
                            
                            <!-- Barangay/District -->
                            <div class="col-md-6">
                                <label class="form-label">Barangay/District</label>
                                <input type="text" name="barangay" class="form-control" placeholder="Barangay or district (optional)">
                            </div>
                            
                            <!-- Delivery Instructions -->
                            <div class="col-12">
                                <label class="form-label">Delivery Instructions <span class="text-muted">(optional)</span></label>
                                <textarea name="delivery_instructions" class="form-control" rows="2" placeholder="e.g., Leave at door, ring doorbell, etc."></textarea>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Delivery Fee -->
                    <div class="col-md-6" id="deliveryFeeSection" style="display: none;">
                        <label class="form-label">Delivery Fee (₱)</label>
                        <input type="number" name="delivery_fee" class="form-control" step="0.01" min="0" value="100" onchange="updateTotal()">
                    </div>
                </form>

                <div class="btn-group-navigation">
                    <button class="btn btn-secondary" onclick="goToStep(1)">
                        <i class="bi bi-arrow-left me-2"></i>Back
                    </button>
                    <button class="btn btn-primary" onclick="goToStep(3)">
                        Next: Payment Method <i class="bi bi-arrow-right ms-2"></i>
                    </button>
                </div>
            </div>

            <!-- Step 3: Payment Method -->
            <div class="checkout-step" id="stepPayment">
                <h2 class="step-title"><i class="bi bi-credit-card me-2"></i>Payment Method</h2>
                
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>Select how you want to pay for this order.
                </div>

                <form id="paymentForm" class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Choose Payment Method</label>
                        <div class="payment-options">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="payment_method" id="paymentCash" value="cash" required>
                                <label class="form-check-label" for="paymentCash">
                                    <i class="bi bi-cash-coin me-2"></i>Cash on Delivery
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="payment_method" id="paymentCard" value="card">
                                <label class="form-check-label" for="paymentCard">
                                    <i class="bi bi-credit-card me-2"></i>Debit/Credit Card
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="payment_method" id="paymentTransfer" value="transfer">
                                <label class="form-check-label" for="paymentTransfer">
                                    <i class="bi bi-bank me-2"></i>Bank Transfer
                                </label>
                            </div>
                        </div>
                    </div>
                </form>

                <div class="btn-group-navigation">
                    <button class="btn btn-secondary" onclick="goToStep(2)">
                        <i class="bi bi-arrow-left me-2"></i>Back
                    </button>
                    <button id="createOrderBtn" class="btn btn-success" onclick="placeOrder()" disabled>
                        <i class="bi bi-check-circle me-2"></i>Create Order
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Order Summary -->
    <div class="col-lg-4">
        <div class="card admin-chart sticky-top" style="top: 20px;">
            <div class="card-header bg-white border-0">
                <h5 class="mb-0"><i class="bi bi-receipt me-2"></i>Order Summary</h5>
            </div>
            <div class="card-body">
                <!-- Selected Customer -->
                <div class="mb-3 pb-3 border-bottom">
                    <p class="text-muted small">Customer</p>
                    <p class="fw-600" style="font-size: 0.95rem;">
                        <i class="bi bi-check-circle text-success"></i> {{ app.user.firstName }} {{ app.user.lastName }}
                    </p>
                </div>

                <!-- Cart Items -->
                <div class="mb-3">
                    <p class="text-muted small">Items</p>
                    <div id="cartItems" style="max-height: 250px; overflow-y: auto;">
                        <p class="text-muted text-center small">No items added</p>
                    </div>
                </div>

                <!-- Delivery Information -->
                <div class="mb-3 pb-3 border-bottom" id="deliverySection" style="display: none;">
                    <p class="text-muted small">Delivery</p>
                    <div style="font-size: 0.9rem;">
                        <div class="mb-2">
                            <small class="text-muted">Type:</small>
                            <small class="fw-600" id="summaryDeliveryType">-</small>
                        </div>
                        <div class="mb-2" id="summaryAddressBlock" style="display: none;">
                            <small class="text-muted">Address:</small>
                            <small class="fw-600 d-block" id="summaryAddress">-</small>
                        </div>
                    </div>
                </div>

                <!-- Payment Information -->
                <div class="mb-3 pb-3 border-bottom" id="paymentSection" style="display: none;">
                    <p class="text-muted small">Payment</p>
                    <div style="font-size: 0.9rem;">
                        <small class="text-muted">Method:</small>
                        <small class="fw-600" id="summaryPaymentMethod">-</small>
                    </div>
                </div>

                <!-- Pricing -->
                <div class="mb-2">
                    <div class="d-flex justify-content-between" style="font-size: 0.95rem;">
                        <span class="text-muted">Subtotal</span>
                        <span id="subtotal">₱0.00</span>
                    </div>
                </div>

                <div class="mb-3 pb-3 border-bottom">
                    <div class="d-flex justify-content-between" style="font-size: 0.95rem;">
                        <span class="text-muted">Delivery Fee</span>
                        <span id="deliveryFee">₱0.00</span>
                    </div>
                </div>

                <!-- Total -->
                <div class="mb-4">
                    <div class="d-flex justify-content-between">
                        <span class="h6 mb-0">Total</span>
                        <span class="h5 mb-0 text-primary" id="totalAmount">₱0.00</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



<script>
let cartItems = {};
let currentStep = 1;

const customerId = document.getElementById('customerId');
const deliveryType = document.getElementById('deliveryType');
const deliveryAddressSection = document.getElementById('deliveryAddressSection');
const deliveryFeeSection = document.getElementById('deliveryFeeSection');
const deliveryFeeInput = document.querySelector('input[name="delivery_fee"]');

// Add listener to delivery fee input
if (deliveryFeeInput) {
    deliveryFeeInput.addEventListener('change', updateTotal);
    deliveryFeeInput.addEventListener('input', updateTotal);
}

function updateDeliveryFields() {
    if (deliveryType.value === 'delivery') {
        deliveryAddressSection.style.display = 'block';
        deliveryFeeSection.style.display = 'block';
        document.getElementById('deliverySection').style.display = 'block';

        fillAddressFields();


    } 
     

    
    
    
    
    else {
        deliveryAddressSection.style.display = 'none';
        deliveryFeeSection.style.display = 'none';
        document.getElementById('deliverySection').style.display = 'none';
        deliveryFeeInput.value = 0;
    }
    updateDeliverySummary();
    updateTotal();
}

// Update delivery summary in sidebar
function updateDeliverySummary() {
    const type = deliveryType.value;
    document.getElementById('summaryDeliveryType').textContent = type === 'delivery' ? 'Delivery' : type === 'pickup' ? 'Pickup' : '-';

    if (type === 'delivery') {
        const recipientName = document.querySelector('input[name="recipient_name"]')?.value || '';
        const streetAddress = document.querySelector('input[name="street_address"]')?.value || '';
        const city = document.querySelector('input[name="city"]')?.value || '';
        const postalCode = document.querySelector('input[name="postal_code"]')?.value || '';
        
        if (recipientName || streetAddress || city) {
            const addressStr = [recipientName, streetAddress, city, postalCode].filter(Boolean).join(', ');
            document.getElementById('summaryAddress').textContent = addressStr;
            document.getElementById('summaryAddressBlock').style.display = 'block';
        } else {
            document.getElementById('summaryAddressBlock').style.display = 'none';
        }
    } else {
        document.getElementById('summaryAddressBlock').style.display = 'none';
    }
}

// Update payment summary in sidebar
function updatePaymentSummary() {
    const paymentMethod = document.querySelector('input[name="payment_method"]:checked');
    const paymentSection = document.getElementById('paymentSection');
    const methodLabels = {
        'cash': 'Cash on Delivery',
        'card': 'Debit/Credit Card',
        'transfer': 'Bank Transfer'
    };

    if (paymentMethod) {
        document.getElementById('summaryPaymentMethod').textContent = methodLabels[paymentMethod.value] || paymentMethod.value;
        paymentSection.style.display = 'block';
    } else {
        paymentSection.style.display = 'none';
    }
}

function goToStep(step) {
    // Hide all steps
    document.querySelectorAll('.checkout-step').forEach(el => el.classList.remove('active'));
    
    // Update progress indicators
    for (let i = 1; i <= 3; i++) {
        const circle = document.getElementById(`step${i}Item`);
        const connector = document.getElementById(`connector${i-1}`);

        circle.classList.remove('active', 'completed');

        if (i < step) {
            circle.classList.add('completed');
            if (connector) connector.classList.add('completed', 'active');
        } else if (i === step) {
            circle.classList.add('active');
        } else {
            if (connector) connector.classList.remove('completed', 'active');
        }
    }

    // Show active step content
    if (step === 1) {
        document.getElementById('stepCart').classList.add('active');
    } else if (step === 2) {
        document.getElementById('stepAddress').classList.add('active');
    } else if (step === 3) {
        document.getElementById('stepPayment').classList.add('active');
    }

    currentStep = step;
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

// Add to cart
document.querySelectorAll('.btn-add-to-cart').forEach(btn => {
    btn.addEventListener('click', function() {
        const productId = this.dataset.productId;
        const productName = this.dataset.productName;
        const qtyInput = document.querySelector(`.product-qty[data-product-id="${productId}"]`);
        const quantity = parseInt(qtyInput.value) || 1;
        const price = parseFloat(qtyInput.dataset.price);

        if (cartItems[productId]) {
            cartItems[productId].quantity += quantity;
        } else {
            cartItems[productId] = {
                name: productName,
                price: price,
                quantity: quantity
            };
        }

        updateCartDisplay();
        qtyInput.value = 1;
    });
});

// Update cart display
function updateCartDisplay() {
    const cartHTML = Object.entries(cartItems).map(([id, item]) => `
        <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom" style="font-size: 0.9rem;">
            <div>
                <small class="fw-600">${item.name}</small>
                <br>
                <small class="text-muted">${item.quantity} × ₱${item.price.toFixed(2)}</small>
            </div>
            <div class="text-end">
                <small class="fw-600">₱${(item.quantity * item.price).toFixed(2)}</small>
                <br>
                <button class="btn btn-sm btn-outline-danger btn-remove-item" data-product-id="${id}" style="padding: 2px 6px;">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
        </div>
    `).join('');

    document.getElementById('cartItems').innerHTML = cartHTML || '<p class="text-muted text-center small">No items added</p>';

    // Attach remove handlers
    document.querySelectorAll('.btn-remove-item').forEach(btn => {
        btn.addEventListener('click', function() {
            delete cartItems[this.dataset.productId];
            updateCartDisplay();
            updateTotal();
        });
    });

    updateTotal();
}

// Update total
function updateTotal() {
    let subtotal = 0;
    Object.values(cartItems).forEach(item => {
        subtotal += item.quantity * item.price;
    });

    let delivery = deliveryType.value === 'delivery' ? parseFloat(deliveryFeeInput.value) || 0 : 0;
    let total = subtotal + delivery;

    document.getElementById('subtotal').textContent = '₱' + subtotal.toFixed(2);
    document.getElementById('deliveryFee').textContent = '₱' + delivery.toFixed(2);
    document.getElementById('totalAmount').textContent = '₱' + total.toFixed(2);

    // Enable/disable create button - check all required conditions
    updateCreateButtonState();

    updateDeliverySummary();
}

// Check if all required fields are filled to enable Create Order button
function updateCreateButtonState() {
    const btn = document.getElementById('createOrderBtn');
    const hasItems = Object.keys(cartItems).length > 0;
    const deliverySelected = deliveryType.value !== '';
    const paymentSelected = document.querySelector('input[name="payment_method"]:checked') !== null;
    
    let deliveryFieldsValid = true;
    if (deliveryType.value === 'delivery') {
        const recipientName = document.querySelector('input[name="recipient_name"]')?.value || '';
        const phoneNumber = document.querySelector('input[name="phone_number"]')?.value || '';
        const streetAddress = document.querySelector('input[name="street_address"]')?.value || '';
        const city = document.querySelector('input[name="city"]')?.value || '';
        const postalCode = document.querySelector('input[name="postal_code"]')?.value || '';
        
        deliveryFieldsValid = recipientName && phoneNumber && streetAddress && city && postalCode;
    }
    
    // Enable button only if: items exist, delivery type selected, address fields valid (if delivery), and payment selected
    btn.disabled = !(hasItems && deliverySelected && deliveryFieldsValid && paymentSelected);
}

// Create order
function placeOrder() {

     console.log('placeOrder called');
console.log('Fetch URL: {{ path("admin_order_new") }}');
    
    const btn = document.getElementById('createOrderBtn');
    
    if (Object.keys(cartItems).length === 0) {
        alert('Please add at least one product');
        goToStep(1);
        return;
    }

    // Validate delivery type is selected
    if (!deliveryType.value) {
        alert('Please select a delivery type');
        goToStep(2);
        return;
    }

    // Validate delivery fields if delivery is selected
    if (deliveryType.value === 'delivery') {
        const recipientName = document.querySelector('input[name="recipient_name"]').value;
        const phoneNumber = document.querySelector('input[name="phone_number"]').value;
        const streetAddress = document.querySelector('input[name="street_address"]').value;
        const city = document.querySelector('input[name="city"]').value;
        const postalCode = document.querySelector('input[name="postal_code"]').value;

        if (!recipientName || !phoneNumber || !streetAddress || !city || !postalCode) {
            alert('Please fill in all required delivery address fields');
            goToStep(2);
            return;
        }
    }

    // Check payment method is selected
    const paymentMethod = document.querySelector('input[name="payment_method"]:checked');
    if (!paymentMethod) {
        alert('Please select a payment method');
        goToStep(3);
        return;
    }

    // Disable button and show loading state
    btn.disabled = true;
    const originalText = btn.innerHTML;
    btn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Processing...';

    // Collect form data
    const formData = new FormData();
    formData.append('customer_id', customerId.value);
    formData.append('delivery_type', deliveryType.value);
    formData.append('payment_method', paymentMethod.value);
    formData.append('is_urgent', document.getElementById('isUrgent').checked ? 1 : 0);
    formData.append('_csrf_token', document.querySelector('input[name="_csrf_token"]').value);
    
    // Add address fields if delivery
    if (deliveryType.value === 'delivery') {
        formData.append('recipient_name', document.querySelector('input[name="recipient_name"]').value);
        formData.append('phone_number', document.querySelector('input[name="phone_number"]').value);
        formData.append('street_address', document.querySelector('input[name="street_address"]').value);
        formData.append('city', document.querySelector('input[name="city"]').value);
        formData.append('postal_code', document.querySelector('input[name="postal_code"]').value);
        formData.append('barangay', document.querySelector('input[name="barangay"]')?.value || '');
        formData.append('delivery_instructions', document.querySelector('textarea[name="delivery_instructions"]')?.value || '');
        formData.append('delivery_fee', deliveryFeeInput.value || 0);
    } else {
        formData.append('delivery_fee', 0);
    }
    
    // Add items
    let itemCount = 0;
    Object.entries(cartItems).forEach(([id, item]) => {
        formData.append(`items[${itemCount}][product_id]`, id);
        formData.append(`items[${itemCount}][quantity]`, item.quantity);
        itemCount++;
    });

    // Submit
    fetch('/admin/orders/new', {
    method: 'POST',
    body: formData,
    credentials: 'same-origin' 
    })


   .then(response => {
    if (response.ok) {
        alert('Order created successfully!');
        window.location.href = '{{ path("admin_orders") }}';
    } else {
        // Read response as text, then try to parse JSON
        response.text().then(text => {
            try {
                const data = JSON.parse(text);
                alert('Error: ' + (data.error || data.message || 'Unknown error'));
            } catch (e) {
                alert('Server error: ' + text);
            }
        });
    }
})
    .catch(error => {
        console.error('Error:', error);
        alert('Error creating order: ' + error.message);
        btn.disabled = false;
        btn.innerHTML = originalText;
        updateCreateButtonState();
    });
}

// Initialize
document.addEventListener('DOMContentLoaded', function() {
    updateTotal();

    // Pre-populate address fields with user's data
    if (userAddress.recipientName) {
        const recipientInput = document.querySelector('input[name="recipient_name"]');
        if (recipientInput) recipientInput.value = userAddress.recipientName;
    }
    if (userAddress.phoneNumber) {
        const phoneInput = document.querySelector('input[name="phone_number"]');
        if (phoneInput) phoneInput.value = userAddress.phoneNumber;
    }
    if (userAddress.streetAddress) {
        const streetInput = document.querySelector('input[name="street_address"]');
        if (streetInput) streetInput.value = userAddress.streetAddress;
    }
    if (userAddress.city) {
        const cityInput = document.querySelector('input[name="city"]');
        if (cityInput) cityInput.value = userAddress.city;
    }
    if (userAddress.postalCode) {
        const postalInput = document.querySelector('input[name="postal_code"]');
        if (postalInput) postalInput.value = userAddress.postalCode;
    }

    // Add listeners for address fields
    const addressFields = ['recipient_name', 'street_address', 'city', 'postal_code', 'phone_number'];
    addressFields.forEach(field => {
        const input = document.querySelector(`input[name="${field}"]`);
        if (input) {
            input.addEventListener('input', function() {
                updateDeliverySummary();
                updateCreateButtonState();
            });
        }
    });

    // Add listener for delivery type
    deliveryType.addEventListener('change', function() {
        updateCreateButtonState();
    });

    // Add listeners for payment method radio buttons
    document.querySelectorAll('input[name="payment_method"]').forEach(radio => {
        radio.addEventListener('change', function() {
            updatePaymentSummary();
            updateCreateButtonState();
        });
    });

    // Update button state after pre-population
    updateCreateButtonState();
});
function fillAddressFields() {
    if (userAddress.streetAddress) {
        const recipientInput = document.querySelector('input[name="recipient_name"]');
        const phoneInput = document.querySelector('input[name="phone_number"]');
        const streetInput = document.querySelector('input[name="street_address"]');
        const cityInput = document.querySelector('input[name="city"]');
        const postalInput = document.querySelector('input[name="postal_code"]');

        if (recipientInput) recipientInput.value = userAddress.recipientName;
        if (phoneInput) phoneInput.value = userAddress.phoneNumber;
        if (streetInput) streetInput.value = userAddress.streetAddress;
        if (cityInput) cityInput.value = userAddress.city;
        if (postalInput) postalInput.value = userAddress.postalCode;
    }
}

const userAddress = {
        recipientName: '{{ app.user.firstName }} {{ app.user.lastName }}',
        streetAddress: '{{ currentUser.userProfile.address|default('') }}',
        city: '{{ currentUser.userProfile.city|default('') }}',
        postalCode: '{{ currentUser.userProfile.zipCode|default('') }}',
        phoneNumber: '{{ app.user.phoneNumber|default('') }}'
    };
</script>


