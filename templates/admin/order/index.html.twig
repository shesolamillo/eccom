{% extends 'layouts/admin.html.twig' %}

{% block title %}Order Management - Admin{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item active">Orders</li>
{% endblock %}

{% block page_title %}Order Management{% endblock %}
{% block page_description %}Manage and process customer orders{% endblock %}

{% block page_actions %}
<a href="{{ path('admin_order_new') }}" class="btn btn-primary">
    <i class="bi bi-plus-circle me-2"></i>Create New Order
</a>
{% endblock %}

{% block admin_content %}
<!-- Order Stats -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card stats-card border-left-primary h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-uppercase text-muted mb-1">Total Orders</h6>
                        <h3 class="fw-bold mb-0">{{ totalOrders|default(0) }}</h3>
                    </div>
                    <div class="stats-icon bg-primary">
                        <i class="bi bi-cart text-white"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="card stats-card border-left-warning h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-uppercase text-muted mb-1">Pending</h6>
                        <h3 class="fw-bold mb-0">{{ pendingOrders|default(0) }}</h3>
                    </div>
                    <div class="stats-icon bg-warning">
                        <i class="bi bi-clock-history text-white"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="card stats-card border-left-info h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-uppercase text-muted mb-1">Processing</h6>
                        <h3 class="fw-bold mb-0">{{ processingOrders|default(0) }}</h3>
                    </div>
                    <div class="stats-icon bg-info">
                        <i class="bi bi-gear text-white"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="card stats-card border-left-success h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-uppercase text-muted mb-1">Completed</h6>
                        <h3 class="fw-bold mb-0">{{ completedOrders|default(0) }}</h3>
                    </div>
                    <div class="stats-icon bg-success">
                        <i class="bi bi-check-circle text-white"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Orders Table -->
<div class="card admin-chart">
    <div class="card-header bg-white border-0">
        <h5 class="mb-0">All Orders</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 data-table">
                <thead class="bg-light">
                    <tr>
                        <th>Order #</th>
                        <th>Customer</th>
                        <th>Date</th>
                        <th>Items</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Payment</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for order in orders %}
                    <tr>
                        <td>
                            <strong>{{ order.orderNumber }}</strong>
                            {% if order.isUrgent %}
                                <span class="badge bg-danger ms-1">Urgent</span>
                            {% endif %}
                        </td>
                        <td>
                            {{ order.customer.firstName }} {{ order.customer.lastName }}<br>
                            <small class="text-muted">{{ order.customer.email }}</small>
                        </td>
                        <td>{{ order.createdAt|date('M d, Y h:i A') }}</td>
                        <td>{{ order.orderItems|length }} items</td>
                        <td class="fw-bold">₱{{ order.totalAmount|number_format(2) }}</td>
                        <td>
                            {% if order.status == 'pending' %}
                                <span class="badge bg-warning">Pending</span>
                            {% elseif order.status == 'processing' %}
                                <span class="badge bg-info">Processing</span>
                            {% elseif order.status == 'completed' %}
                                <span class="badge bg-success">Completed</span>
                            {% elseif order.status == 'cancelled' %}
                                <span class="badge bg-secondary">Cancelled</span>
                            {% elseif order.status == 'declined' %}
                                <span class="badge bg-danger">Declined</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if order.isPaid %}
                                <span class="badge bg-success">Paid</span>
                            {% else %}
                                <span class="badge bg-warning">Unpaid</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a href="{{ path('admin_order_manage', {'id': order.id}) }}" 
                                   class="btn btn-outline-primary" title="Manage">
                                    <i class="bi bi-gear"></i>
                                </a>
                                <a href="{{ path('admin_order_show', {'id': order.id}) }}" 
                                   class="btn btn-outline-info" title="View">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            <i class="bi bi-cart-x fs-1"></i>
                            <p class="mt-2">No orders found</p>
                            <a href="{{ path('admin_order_new') }}" class="btn btn-primary">
                                Create Your First Order
                            </a>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}