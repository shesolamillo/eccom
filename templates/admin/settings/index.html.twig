{# templates/admin/settings/index.html.twig #}
{% extends 'layouts/admin.html.twig' %}

{% block title %}System Settings - SMSol Studio{% endblock %}

{% block page_title %}System Settings{% endblock %}

{% block admin_content %}
<div class="card">
    <div class="card-header bg-white">
        <h5 class="mb-0">Settings Management</h5>
    </div>
    <div class="card-body">
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            Settings functionality is coming soon. For now, you can manage settings directly in the database.
        </div>
        
        <div class="row">
            <div class="col-md-4">
                <div class="card mb-3">
                    <div class="card-body">
                        <h6><i class="bi bi-gear text-primary me-2"></i>General Settings</h6>
                        <p class="text-muted small">Store information, business hours, and basic configuration</p>
                    </div>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card mb-3">
                    <div class="card-body">
                        <h6><i class="bi bi-envelope text-success me-2"></i>Email Settings</h6>
                        <p class="text-muted small">SMTP configuration and email templates</p>
                    </div>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card mb-3">
                    <div class="card-body">
                        <h6><i class="bi bi-credit-card text-warning me-2"></i>Payment Settings</h6>
                        <p class="text-muted small">Payment methods and transaction settings</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}